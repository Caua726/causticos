// driver.cst — Driver framework base (spec v2, step 1)
//
// Provides: Device/Driver/BusType/BusInstance structs, state constants,
// DriverResult codes, the synthetic root device, and driver_framework_init.
//
// Operations (device_register, bus_register_driver, probing, resources) land
// in later commits per the spec's Implementation Order.

use "pmm.cst" as pmm;
use "heap.cst" as heap;
use "serial.cst" as serial;
use "sched.cst" as sched;

// ============================================================
// DeviceState
// ============================================================

let is i32 as STATE_UNINITIALIZED = 0;
let is i32 as STATE_PROBED        = 1;
let is i32 as STATE_DETACHING     = 2;
let is i32 as STATE_DEAD          = 3;

// ============================================================
// DriverResult — OK=0, errors positive
// ============================================================

let is i32 as OK                       = 0;
let is i32 as OUT_OF_MEMORY            = 1;
let is i32 as PERMISSION_DENIED        = 2;
let is i32 as DEVICE_BUSY              = 3;
let is i32 as DEVICE_NOT_PRESENT       = 4;
let is i32 as INVALID_ARGUMENT         = 5;
let is i32 as NOT_SUPPORTED            = 6;
let is i32 as ALREADY_EXISTS           = 7;
let is i32 as NOT_FOUND                = 8;
let is i32 as DUPLICATE_DRIVER_NAME    = 9;
let is i32 as DUPLICATE_PRIORITY       = 10;
let is i32 as INVALID_MATCH_SPEC       = 11;
let is i32 as BUS_NOT_REGISTERED       = 12;
let is i32 as NO_DRIVER_MATCHED        = 13;
let is i32 as MMIO_ALREADY_MAPPED      = 14;
let is i32 as MMIO_INVALID_INDEX       = 15;
let is i32 as NO_IRQ_VECTORS           = 16;
let is i32 as IRQ_INVALID_VECTOR       = 17;
let is i32 as DMA_OUT_OF_MEMORY        = 18;
let is i32 as DMA_ADDRESS_CONSTRAINT   = 19;
let is i32 as INVALID_STATE_TRANSITION = 20;

// ============================================================
// Resource list nodes
// ============================================================

struct MmioRegion {
    phys as u64;
    size as u64;
    flags as u32;
    _pad as u32;
    mapped_at as *u8;
    next as *MmioRegion;
}

struct IrqBinding {
    vector as u32;
    kind as i32;
    handler as *u8;   // fn(*Device, *u8) as i32
    context as *u8;
    next as *IrqBinding;
}

struct DmaBuffer {
    virt as *u8;
    phys as u64;
    size as u64;
    next as *DmaBuffer;
}

// ============================================================
// Core structs
// ============================================================

struct BusType {
    name as [32]u8;
    match_fn as fn(*BusType, *Device, *Driver) as i32;
    enumerate_instance as fn(*BusInstance) as void;
    drivers as *Driver;
    driver_count as u32;
    instance_count as u32;
    instances as *BusInstance;
    lock as i32;
    _pad as i32;
    next as *BusType;
}

struct Driver {
    name as [32]u8;
    bus_type as *BusType;
    match_spec as *u8;
    probe as fn(*Device) as i32;
    remove as fn(*Device) as void;
    priority as i32;
    _pad as i32;
    next as *Driver;
}

struct Device {
    name as [32]u8;
    parent as *Device;
    first_child as *Device;
    next_sibling as *Device;
    prev_sibling as *Device;
    bus_type as *BusType;
    driver as *Driver;
    private as *u8;
    state as i32;
    lock as i32;                 // spinlock stub; single-CPU for now
    mmio_list as *MmioRegion;
    irq_list as *IrqBinding;
    dma_list as *DmaBuffer;
}

struct BusInstance {
    base as Device;
    next as *BusInstance;
}

// ============================================================
// Globals
// ============================================================

let is i64 as root_device with mut = 0;
let is i64 as bus_types with mut = 0;
let is i32 as bus_type_count with mut = 0;
let is i32 as driver_tree_lock with mut = 0;

// ============================================================
// Init
// ============================================================

fn init() as void {
    serial.print("driver: init ", 13);
    let is i64 as addr = heap.kmalloc(sizeof(Device), 0);
    if (addr == 0) {
        pmm.panic("driver: root alloc failed", 25);
    }
    let is *Device as root = cast(*Device, addr);
    // Zero the struct
    let is *u8 as p = cast(*u8, addr);
    let is i64 as i with mut = 0;
    while (i < sizeof(Device)) {
        p[i] = cast(u8, 0);
        i = i + 1;
    }
    root.name[0] = cast(u8, 114); // 'r'
    root.name[1] = cast(u8, 111); // 'o'
    root.name[2] = cast(u8, 111); // 'o'
    root.name[3] = cast(u8, 116); // 't'
    root.state = STATE_UNINITIALIZED;
    root_device = addr;
    serial.println("ok", 2);
}

fn get_root() as *Device {
    return cast(*Device, root_device);
}

// ============================================================
// Tree lock — single-CPU: block preemption, don't touch IRQ flag.
// Composable: preempt_count is a counter, nested locks are safe.
// Lock ordering (for future bus-type lock): always acquire tree_lock
// BEFORE any bus-specific lock.
// ============================================================

fn tree_lock() as void {
    sched.preempt_disable();
    driver_tree_lock = 1;
}

fn tree_unlock() as void {
    driver_tree_lock = 0;
    sched.preempt_enable();
}

// ============================================================
// Device allocation + lifecycle
// ============================================================

// kmalloc's second arg is flags, not alignment. The current kernel has no
// alignment-aware allocator; kmalloc slabs are naturally pointer-aligned
// (8 bytes), which satisfies every Device-sized allocation today. The
// align parameter is kept in the signature per spec for forward-compat.
fn device_alloc(size as i64, align as i64) as *Device {
    let is i64 as addr = heap.kmalloc(size, 0);
    if (addr == 0) { return cast(*Device, 0); }
    let is *u8 as p = cast(*u8, addr);
    let is i64 as i with mut = 0;
    while (i < size) {
        p[i] = cast(u8, 0);
        i = i + 1;
    }
    return cast(*Device, addr);
}

// Links dev into parent's child list. Caller must have populated dev's
// bus-specific fields (and dev.bus_type if dev is a BusInstance).
// Returns OK, INVALID_ARGUMENT. Panics on double-registration.
fn device_register(dev as *Device, parent as *Device) as i32 {
    if (cast(i64, dev) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, dev.parent) != 0) {
        pmm.panic("device_register: already registered", 35);
    }

    tree_lock();

    dev.parent = parent;
    dev.first_child = cast(*Device, 0);
    dev.next_sibling = cast(*Device, 0);
    dev.prev_sibling = cast(*Device, 0);

    if (cast(i64, parent) != 0) {
        // Inherit bus_type from parent unless caller already set it
        // (BusInstance pre-sets its own bus_type per spec fix #15).
        if (cast(i64, dev.bus_type) == 0) {
            dev.bus_type = parent.bus_type;
        }
        let is *Device as old_head = parent.first_child;
        dev.next_sibling = old_head;
        if (cast(i64, old_head) != 0) {
            old_head.prev_sibling = dev;
        }
        parent.first_child = dev;
    }

    tree_unlock();
    return OK;
}

// Panics on invariant violation (state != DEAD, has children, or resources
// still tracked). Unlinks dev from the tree and frees it.
fn device_unregister(dev as *Device) as void {
    if (cast(i64, dev) == 0) {
        pmm.panic("device_unregister: null dev", 27);
    }

    tree_lock();

    if (dev.state != STATE_DEAD) {
        pmm.panic("device_unregister: not DEAD", 27);
    }
    if (cast(i64, dev.first_child) != 0) {
        pmm.panic("device_unregister: has children", 31);
    }

    if (cast(i64, dev.parent) != 0) {
        let is *Device as parent = dev.parent;
        if (cast(i64, dev.prev_sibling) == 0) {
            parent.first_child = dev.next_sibling;
        } else {
            dev.prev_sibling.next_sibling = dev.next_sibling;
        }
        if (cast(i64, dev.next_sibling) != 0) {
            dev.next_sibling.prev_sibling = dev.prev_sibling;
        }
    }

    tree_unlock();

    release_all_resources(dev);
    heap.kfree(cast(i64, dev));
}

// ============================================================
// BusType + BusInstance registration
// ============================================================

// Links bt into the global bus_types list. Rejects re-registration by
// pointer identity. bt's drivers/instances/counters are expected to be
// zero-initialized by the caller (static .bus_types entries satisfy this).
fn bus_type_register(bt as *BusType) as i32 {
    if (cast(i64, bt) == 0) { return INVALID_ARGUMENT; }

    tree_lock();
    let is *BusType as cur with mut = cast(*BusType, bus_types);
    while (cast(i64, cur) != 0) {
        if (cast(i64, cur) == cast(i64, bt)) {
            tree_unlock();
            return ALREADY_EXISTS;
        }
        cur = cur.next;
    }
    bt.next = cast(*BusType, bus_types);
    bus_types = cast(i64, bt);
    bus_type_count = bus_type_count + 1;
    tree_unlock();
    return OK;
}

// Registers a BusInstance in the device tree and in its BusType's flat
// instance list. Caller must set bi.base.bus_type before calling (spec
// fix #15). Lock ordering: device_register acquires the tree lock; the
// bus-type lock is acquired strictly after tree operations complete.
fn bus_instance_register(bi as *BusInstance, parent as *Device) as i32 {
    if (cast(i64, bi) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, bi.base.bus_type) == 0) { return INVALID_ARGUMENT; }
    let is *BusType as bt = bi.base.bus_type;

    let is i32 as rc = device_register(cast(*Device, bi), parent);
    if (rc != OK) { return rc; }

    // Single-CPU: preempt_disable doubles as bt.lock.
    sched.preempt_disable();
    bi.next = bt.instances;
    bt.instances = bi;
    bt.instance_count = bt.instance_count + cast(u32, 1);
    sched.preempt_enable();

    return OK;
}

// ============================================================
// Resource subsystems: MMIO / IRQ / DMA
//
// Resources are tracked per-device in three singly-linked lists. The lists
// start empty (null). Allocations prepend; releases scan-and-unlink.
// device_unregister drains all three in order IRQ -> DMA -> MMIO
// per spec §Cleanup Ordering.
//
// Limitations for V1:
//   - mmio_map hands out HHDM aliases (limine's phys->virt direct map).
//     Cacheability is whatever HHDM uses (write-back); real MMIO needing
//     uncached access will require a dedicated vmm.mmio_map helper.
//   - dma_alloc supports up to one page (PAGE_SIZE = 4096). Multi-page
//     contiguous allocations need alloc_pages with order>0; added later.
//   - irq_register tracks the binding but does not yet program the IDT or
//     LAPIC — that wiring lives in the IRQ subsystem commit.
// ============================================================

fn mmio_map(dev as *Device, phys as u64, size as u64, flags as u32, out as **u8) as i32 {
    if (cast(i64, dev) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, out) == 0) { return INVALID_ARGUMENT; }

    let is i64 as node_addr = heap.kmalloc(sizeof(MmioRegion), 0);
    if (node_addr == 0) { return OUT_OF_MEMORY; }
    let is *MmioRegion as r = cast(*MmioRegion, node_addr);
    r.phys = phys;
    r.size = size;
    r.flags = flags;
    r.mapped_at = cast(*u8, pmm.hhdm + cast(i64, phys));

    sched.preempt_disable();
    r.next = dev.mmio_list;
    dev.mmio_list = r;
    sched.preempt_enable();

    *out = r.mapped_at;
    return OK;
}

fn mmio_unmap(dev as *Device, region as *MmioRegion) as void {
    if (cast(i64, dev) == 0) { return; }
    if (cast(i64, region) == 0) { return; }

    sched.preempt_disable();
    let is *MmioRegion as cur with mut = dev.mmio_list;
    let is *MmioRegion as prev with mut = cast(*MmioRegion, 0);
    while (cast(i64, cur) != 0) {
        if (cast(i64, cur) == cast(i64, region)) {
            if (cast(i64, prev) == 0) { dev.mmio_list = cur.next; }
            else                       { prev.next = cur.next; }
            sched.preempt_enable();
            heap.kfree(cast(i64, cur));
            return;
        }
        prev = cur;
        cur = cur.next;
    }
    sched.preempt_enable();
}

fn dma_alloc(dev as *Device, size as u64, align as u64, flags as u32, out as **DmaBuffer) as i32 {
    if (cast(i64, dev) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, out) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, size) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, size) > pmm.PAGE_SIZE) { return NOT_SUPPORTED; }

    let is i32 as zone with mut = pmm.ZONE_NORMAL;
    let is i32 as alloc_flags with mut = pmm.ALLOC_ZERO;
    if ((flags & cast(u32, 1)) != cast(u32, 0)) {          // DMA_32BIT_ONLY
        zone = pmm.ZONE_DMA32;
        alloc_flags = alloc_flags | pmm.ALLOC_DMA32_ONLY;
    }

    let is i32 as pfn = pmm.alloc_pages(zone, alloc_flags, cast(i32, 0), pmm.USAGE_KERNEL, cast(i32, 0));
    if (pfn == pmm.PFN_NONE) { return DMA_OUT_OF_MEMORY; }
    let is i64 as phys = pmm.pfn_to_phys(pfn);

    let is i64 as node_addr = heap.kmalloc(sizeof(DmaBuffer), 0);
    if (node_addr == 0) {
        pmm.free_pages(pfn);
        return OUT_OF_MEMORY;
    }
    let is *DmaBuffer as b = cast(*DmaBuffer, node_addr);
    b.virt = cast(*u8, pmm.hhdm + phys);
    b.phys = cast(u64, phys);
    b.size = size;

    sched.preempt_disable();
    b.next = dev.dma_list;
    dev.dma_list = b;
    sched.preempt_enable();

    *out = b;
    return OK;
}

fn dma_free(dev as *Device, buffer as *DmaBuffer) as void {
    if (cast(i64, dev) == 0) { return; }
    if (cast(i64, buffer) == 0) { return; }

    sched.preempt_disable();
    let is *DmaBuffer as cur with mut = dev.dma_list;
    let is *DmaBuffer as prev with mut = cast(*DmaBuffer, 0);
    while (cast(i64, cur) != 0) {
        if (cast(i64, cur) == cast(i64, buffer)) {
            if (cast(i64, prev) == 0) { dev.dma_list = cur.next; }
            else                       { prev.next = cur.next; }
            sched.preempt_enable();
            let is i32 as pfn = cast(i32, cast(i64, cur.phys) / pmm.PAGE_SIZE);
            pmm.free_pages(pfn);
            heap.kfree(cast(i64, cur));
            return;
        }
        prev = cur;
        cur = cur.next;
    }
    sched.preempt_enable();
}

// IRQ tracking only in V1 — the framework does not yet program the IDT or
// LAPIC. Drivers that register a handler will not receive interrupts until
// the IRQ subsystem is wired up in a later commit.
fn irq_register(dev as *Device, vector as u32, kind as i32,
                handler as *u8, context as *u8) as i32 {
    if (cast(i64, dev) == 0) { return INVALID_ARGUMENT; }

    let is i64 as node_addr = heap.kmalloc(sizeof(IrqBinding), 0);
    if (node_addr == 0) { return OUT_OF_MEMORY; }
    let is *IrqBinding as b = cast(*IrqBinding, node_addr);
    b.vector = vector;
    b.kind = kind;
    b.handler = handler;
    b.context = context;

    sched.preempt_disable();
    b.next = dev.irq_list;
    dev.irq_list = b;
    sched.preempt_enable();
    return OK;
}

fn irq_unregister(dev as *Device, vector as u32) as void {
    if (cast(i64, dev) == 0) { return; }

    sched.preempt_disable();
    let is *IrqBinding as cur with mut = dev.irq_list;
    let is *IrqBinding as prev with mut = cast(*IrqBinding, 0);
    while (cast(i64, cur) != 0) {
        if (cur.vector == vector) {
            if (cast(i64, prev) == 0) { dev.irq_list = cur.next; }
            else                       { prev.next = cur.next; }
            sched.preempt_enable();
            heap.kfree(cast(i64, cur));
            return;
        }
        prev = cur;
        cur = cur.next;
    }
    sched.preempt_enable();
}

// Drains all tracked resources in spec-mandated order IRQ -> DMA -> MMIO.
// Idempotent: called from device_unregister; safe on empty lists.
fn release_all_resources(dev as *Device) as void {
    while (cast(i64, dev.irq_list) != 0) {
        let is *IrqBinding as head = dev.irq_list;
        irq_unregister(dev, head.vector);
    }
    while (cast(i64, dev.dma_list) != 0) {
        let is *DmaBuffer as head = dev.dma_list;
        dma_free(dev, head);
    }
    while (cast(i64, dev.mmio_list) != 0) {
        let is *MmioRegion as head = dev.mmio_list;
        mmio_unmap(dev, head);
    }
}

// ============================================================
// Init-section iteration
//
// The spec describes four sections (.bus_types, .drivers_init.bus,
// .drivers_init.driver, .drivers_init.late) iterated in ascending `order`
// value. caustic-ld currently strips section names from the final ELF and
// does not emit __start_SECNAME / __stop_SECNAME markers, so automatic
// discovery of entries is not yet available.
//
// Until the linker gains that feature, buses and drivers register themselves
// by calling `bus_type_register` / `bus_register_driver` from a bootstrap
// hook. The four functions below are the wiring points the _kernel_start
// path will call; each bus/driver module contributes by providing a function
// that adds itself to the relevant list, and the kernel binds those hooks
// statically.
//
// For now these are stubs. They are introduced so callers can be written
// against the final API shape; the internals fill in once section iteration
// becomes available or when a central registration table is wired.
// ============================================================

fn driver_register_bus_types() as void {
    // Filled by manual calls until section iteration is available.
}

fn driver_init_buses() as void {
    // Creates BusInstances for each registered BusType. Buses provide their
    // own enumerate-entry hook.
}

fn driver_init_drivers() as void {
    // Calls bus_register_driver for each statically-linked driver.
}

fn driver_enumerate_all() as void {
    // For each BusType with instances, calls bt.enumerate_instance(bi) to
    // create UNINITIALIZED devices. No probing yet — Phase 1 only.
    let is *BusType as bt with mut = cast(*BusType, bus_types);
    while (cast(i64, bt) != 0) {
        if (cast(i64, bt.enumerate_instance) != 0) {
            let is *BusInstance as bi with mut = bt.instances;
            while (cast(i64, bi) != 0) {
                call(bt.enumerate_instance, bi);
                bi = bi.next;
            }
        }
        bt = bt.next;
    }
}

fn driver_late_init() as void {
    // Deferred hooks that run after probing. No-op until callers wire in.
}

// Depth-first walk: probe the parent first so a bridge's probe can create
// children which are then probed in turn. Devices with null bus_type (root)
// are skipped. next_sibling is snapshotted before probing in case the list
// is mutated during probe (e.g. child registration).
fn probe_subtree(dev as *Device) as void {
    if (cast(i64, dev) == 0) { return; }
    if (dev.state == STATE_UNINITIALIZED && cast(i64, dev.bus_type) != 0) {
        bus_probe_device(dev.bus_type, dev);
    }
    let is *Device as c with mut = dev.first_child;
    while (cast(i64, c) != 0) {
        let is *Device as next = c.next_sibling;
        probe_subtree(c);
        c = next;
    }
}

fn driver_probe_all() as void {
    probe_subtree(cast(*Device, root_device));
}

// Entry point dispatched by sched.start as the first kernel thread. Runs
// Phase 2 (probing + late init) with the scheduler fully online so probes
// may block, sleep, or spawn workers.
fn driver_init_thread() as void {
    serial.println("driver: phase 2 start", 21);
    driver_probe_all();
    driver_late_init();
    serial.println("driver: phase 2 done", 20);
    // Thread exits; scheduler reclaims it.
}

// ============================================================
// Driver registration, matching, probing
// ============================================================

// Byte-compare two [32]u8 name buffers. Equal if all 32 bytes match, or if
// they match up to and including a shared null terminator.
fn name32_eq(a as *u8, b as *u8) as i32 {
    let is i64 as i with mut = 0;
    while (i < 32) {
        if (a[i] != b[i]) { return 0; }
        if (cast(i64, a[i]) == 0) { return 1; }
        i = i + 1;
    }
    return 1;
}

// Registers drv under bt. Enforces both name uniqueness and priority
// uniqueness (spec fix #5). On success, drv.bus_type is set and drv is
// linked into bt.drivers.
fn bus_register_driver(bt as *BusType, drv as *Driver) as i32 {
    if (cast(i64, bt) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, drv) == 0) { return INVALID_ARGUMENT; }

    sched.preempt_disable();

    let is *Driver as cur with mut = bt.drivers;
    while (cast(i64, cur) != 0) {
        if (cast(i64, cur) == cast(i64, drv)) {
            sched.preempt_enable();
            return ALREADY_EXISTS;
        }
        if (name32_eq(&cur.name[0], &drv.name[0]) == 1) {
            sched.preempt_enable();
            return DUPLICATE_DRIVER_NAME;
        }
        if (cur.priority == drv.priority) {
            sched.preempt_enable();
            return DUPLICATE_PRIORITY;
        }
        cur = cur.next;
    }

    drv.bus_type = bt;
    drv.next = bt.drivers;
    bt.drivers = drv;
    bt.driver_count = bt.driver_count + cast(u32, 1);

    sched.preempt_enable();
    return OK;
}

// Iterate bt.drivers, invoke bt.match_fn on each, pick the winner by
// drv.priority (unique within a bus, so no tie-breaking is needed).
// Calls winner.probe on success, transitions dev.state accordingly.
// Returns OK on PROBED, NO_DRIVER_MATCHED if no driver qualified (dev
// stays UNINITIALIZED), or the probe's own DriverResult on probe failure
// (dev transitions to DEAD and caller is expected to device_unregister).
fn bus_probe_device(bt as *BusType, dev as *Device) as i32 {
    if (cast(i64, bt) == 0) { return INVALID_ARGUMENT; }
    if (cast(i64, dev) == 0) { return INVALID_ARGUMENT; }

    let is *Driver as best with mut = cast(*Driver, 0);
    let is i32 as best_pri with mut = 0;

    sched.preempt_disable();
    let is *Driver as cur with mut = bt.drivers;
    while (cast(i64, cur) != 0) {
        let is i32 as matched = call(bt.match_fn, bt, dev, cur);
        if (matched == 1) {
            if (cast(i64, best) == 0) {
                best = cur;
                best_pri = cur.priority;
            } else {
                if (cur.priority > best_pri) {
                    best = cur;
                    best_pri = cur.priority;
                }
            }
        }
        cur = cur.next;
    }
    sched.preempt_enable();

    if (cast(i64, best) == 0) {
        return NO_DRIVER_MATCHED;
    }

    let is i32 as probe_rc = call(best.probe, dev);
    if (probe_rc != OK) {
        device_set_state(dev, STATE_DEAD);
        return probe_rc;
    }

    dev.driver = best;
    device_set_state(dev, STATE_PROBED);
    return OK;
}

// Validates a state transition and applies it under the tree lock
// (single-CPU: sufficient coverage; SMP will refine to per-device lock).
// Returns OK or INVALID_STATE_TRANSITION.
fn device_set_state(dev as *Device, new_state as i32) as i32 {
    tree_lock();
    let is i32 as cur = dev.state;
    let is i32 as valid with mut = 0;
    if (cur == STATE_UNINITIALIZED && new_state == STATE_PROBED)    { valid = 1; }
    if (cur == STATE_UNINITIALIZED && new_state == STATE_DEAD)      { valid = 1; }
    if (cur == STATE_PROBED        && new_state == STATE_DETACHING) { valid = 1; }
    if (cur == STATE_DETACHING     && new_state == STATE_DEAD)      { valid = 1; }
    if (valid == 0) {
        tree_unlock();
        return INVALID_STATE_TRANSITION;
    }
    dev.state = new_state;
    tree_unlock();
    return OK;
}
