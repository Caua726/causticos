// main.cst — causticos kernel entry point

use "limine.cst" as limine;
use "fb.cst" as fb;
use "serial.cst" as serial;
use "gdt.cst" as gdt;
use "idt.cst" as idt;
use "../font/font8x8.cst" as font;
use "pmm.cst" as pmm;
use "heap.cst" as heap;
use "vmm.cst" as vmm;
use "timer.cst" as timer;
use "sched.cst" as sched;

fn halt() as void {
    asm("cli\n");
    while (1 == 1) {
        asm(".byte 0xF4\n");
    }
}

fn test_thread_a() as void {
    let is i64 as i with mut = 0;
    while (i < 5) {
        serial.println("thread A", 8);
        sched.yield_cpu();
        i = i + 1;
    }
    serial.println("thread A done", 13);
}

fn test_thread_b() as void {
    let is i64 as i with mut = 0;
    while (i < 5) {
        serial.println("thread B", 8);
        sched.yield_cpu();
        i = i + 1;
    }
    serial.println("thread B done", 13);
}

let is i64 as fn_addr_a with mut = 0;
let is i64 as fn_addr_b with mut = 0;

fn _kernel_start() as void {
    if (limine.fb_req_response == 0) {
        halt();
    }
    let is *limine.LimineFbResponse as resp = cast(*limine.LimineFbResponse, limine.fb_req_response);
    if (resp.fb_count == 0) {
        halt();
    }
    let is *i64 as fbarr = cast(*i64, resp.framebuffers);
    let is *limine.LimineFramebuffer as framebuffer = cast(*limine.LimineFramebuffer, fbarr[0]);

    serial.init();
    serial.println("causticos v0.0.1", 16);
    gdt.init();
    timer.init();
    idt.init();
    font.init();
    serial.println("boot ok", 7);

    pmm.init();
    heap.init();
    vmm.init();

    fb.init(framebuffer);
    fb.clear(cast(i32, 0x001a1a2e));
    fb.print("causticos", 9, 10, 10, cast(i32, 0x00FFFFFF));

    sched.init();

    // Get function addresses via asm (Caustic can't take &fn)
    // main.cst is root file — symbols have no module prefix
    asm("lea rax, [rip+test_thread_a]\n");
    asm("lea rbx, [rip+fn_addr_a]\n");
    asm("mov QWORD PTR [rbx], rax\n");
    asm("lea rax, [rip+test_thread_b]\n");
    asm("lea rbx, [rip+fn_addr_b]\n");
    asm("mov QWORD PTR [rbx], rax\n");

    sched.create_thread(fn_addr_a, sched.QOS_NORMAL);
    sched.create_thread(fn_addr_b, sched.QOS_NORMAL);

    serial.println("starting scheduler", 18);
    sched.start();
}
