// util.cst — shared utility functions (no dependencies except serial)

use "serial.cst" as serial;

fn print_num(n as i64) as void {
    if (n == 0) {
        serial.putc(48);
        return;
    }
    let is [20]u8 as buf;
    let is i64 as val with mut = n;
    let is i64 as pos with mut = 19;
    while (val > 0) {
        buf[pos] = cast(u8, (val % 10) + 48);
        val = val / 10;
        pos = pos - 1;
    }
    let is i64 as start with mut = pos + 1;
    while (start < 20) {
        serial.putc(cast(i64, buf[start]));
        start = start + 1;
    }
}

fn print_hex(n as i64) as void {
    serial.putc(48);
    serial.putc(120);
    let is [16]u8 as buf;
    let is i64 as val with mut = n;
    let is i64 as i with mut = 15;
    while (i >= 0) {
        let is i64 as digit = val & 0xF;
        if (digit < 10) {
            buf[i] = cast(u8, digit + 48);
        } else {
            buf[i] = cast(u8, digit + 87);
        }
        val = val >> 4;
        i = i - 1;
    }
    i = 0;
    while (i < 16) {
        serial.putc(cast(i64, buf[i]));
        i = i + 1;
    }
}
