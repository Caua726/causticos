// serial.cst — COM1 serial output for debug logging

use "port.cst" as port;

let is i64 as COM1 = 0x3F8;

fn init() as void {
    port.outb(COM1 + 1, 0);    // disable interrupts
    port.outb(COM1 + 3, 0x80); // enable DLAB (set baud divisor)
    port.outb(COM1 + 0, 1);    // divisor 1 = 115200 baud
    port.outb(COM1 + 1, 0);    // divisor hi byte
    port.outb(COM1 + 3, 0x03); // 8 bits, no parity, one stop bit
    port.outb(COM1 + 2, 0xC7); // enable FIFO, clear, 14-byte threshold
    port.outb(COM1 + 4, 0x0B); // MCR: DTR + RTS + OUT2
}

fn putc(ch as i64) as void {
    port.outb(COM1, ch);
}

fn print(str as *u8, len as i64) as void {
    let is i64 as i with mut = 0;
    while (i < len) {
        putc(cast(i64, str[i]));
        i = i + 1;
    }
}

fn println(str as *u8, len as i64) as void {
    print(str, len);
    putc(13);
    putc(10);
}
