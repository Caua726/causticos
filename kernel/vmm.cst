// vmm.cst — Virtual Memory Manager
// x86_64 4-level paging: PML4 → PDPT → PD → PT → 4KB page
// Based on causticos_vmm_spec_v1

use "serial.cst" as serial;
use "pmm.cst" as pmm;
use "heap.cst" as heap;
use "idt.cst" as idt;

// ============================================================
// PTE flags
// ============================================================

let is i64 as PTE_PRESENT   = 1;
let is i64 as PTE_WRITE     = 2;
let is i64 as PTE_USER      = 4;
let is i64 as PTE_PWT       = 8;
let is i64 as PTE_PCD       = 16;
let is i64 as PTE_ACCESSED  = 32;
let is i64 as PTE_DIRTY     = 64;
let is i64 as PTE_HUGE      = 128;
let is i64 as PTE_GLOBAL    = 256;
let is i64 as PTE_NX with mut = 0;
let is i64 as PTE_ADDR_MASK with mut = 0;

// Common flag combos (set at init)
let is i64 as PTE_TABLE with mut = 0;       // PRESENT | WRITE | NX
let is i64 as PTE_TABLE_USER with mut = 0;  // PRESENT | WRITE | USER | NX
let is i64 as KMAP_DATA with mut = 0;       // PRESENT | WRITE | NX

// Address space layout
let is i64 as USER_SPACE_END with mut = 0;
let is i64 as PML4_KERNEL_START = 256;
let is i64 as PML4_KERNEL_END  = 511;

// kvalloc range
let is i64 as KVALLOC_BASE  = 0xFFFFC00000000000;
let is i64 as KVALLOC_PAGES = 262144;       // 1 GiB / 4 KiB

// ============================================================
// Paging index extraction
// ============================================================

fn pml4_index(v as i64) as i64 { return (v >> 39) & 511; }
fn pdpt_index(v as i64) as i64 { return (v >> 30) & 511; }
fn pd_index(v as i64) as i64   { return (v >> 21) & 511; }
fn pt_index(v as i64) as i64   { return (v >> 12) & 511; }

// ============================================================
// CR3 / TLB
// ============================================================

let is i64 as cr3_val with mut = 0;

fn read_cr3() as i64 {
    asm(".byte 0x0F, 0x20, 0xD8\n");  // mov rax, cr3
    asm("lea rbx, [rip+_kernel_vmm_cst_cr3_val]\n");
    asm("mov QWORD PTR [rbx], rax\n");
    return cr3_val;
}

fn write_cr3(val as i64) as void {
    asm(".byte 0x0F, 0x22, 0xDF\n");  // mov cr3, rdi
}

fn invlpg(vaddr as i64) as void {
    asm(".byte 0x0F, 0x01, 0x3F\n");  // invlpg [rdi]
}

fn flush_tlb_full() as void {
    let is i64 as c = read_cr3();
    write_cr3(c);
}

fn flush_tlb_range(vaddr as i64, count as i64) as void {
    let is i64 as i with mut = 0;
    while (i < count) {
        invlpg(vaddr + i * pmm.PAGE_SIZE);
        i = i + 1;
    }
}

// ============================================================
// IRQ lock
// ============================================================

let is i64 as vmm_saved_flags with mut = 0;

fn virq_save() as void {
    asm(".byte 0x9C\n");
    asm("pop rax\n");
    asm("lea rbx, [rip+_kernel_vmm_cst_vmm_saved_flags]\n");
    asm("mov QWORD PTR [rbx], rax\n");
    asm(".byte 0xFA\n");
}

fn virq_restore() as void {
    asm("lea rbx, [rip+_kernel_vmm_cst_vmm_saved_flags]\n");
    asm("mov rax, QWORD PTR [rbx]\n");
    asm("push rax\n");
    asm(".byte 0x9D\n");
}

// ============================================================
// PTE helpers
// ============================================================

fn pte_read(tphys as i64, idx as i64) as i64 {
    let is *i64 as t = cast(*i64, pmm.phys_to_virt(tphys));
    return t[idx];
}

fn pte_write(tphys as i64, idx as i64, val as i64) as void {
    let is *i64 as t = cast(*i64, pmm.phys_to_virt(tphys));
    t[idx] = val;
}

fn pte_addr(pte as i64) as i64 { return pte & PTE_ADDR_MASK; }
fn pte_present(pte as i64) as i64 { return pte & PTE_PRESENT; }

fn alloc_table_page(owner as i32) as i64 {
    let is i32 as pfn = pmm.alloc_pages(
        pmm.ZONE_DMA32,
        pmm.ALLOC_ZERO | pmm.ALLOC_ALLOW_FALLBACK,
        cast(i32, 0), pmm.USAGE_PAGE_TABLE, owner
    );
    if (pfn == pmm.PFN_NONE) {
        pmm.panic("vmm: alloc_table_page OOM", 25);
    }
    return pmm.pfn_to_phys(pfn);
}

// ============================================================
// Kernel address space
// ============================================================

// Kernel AS: pml4_phys, pml4_virt, as_id=0
let is i64 as kas_pml4_phys with mut = 0;
let is i64 as kas_pml4_virt with mut = 0;

// User AS list (for kernel PML4 sync)
// Simple array of pml4_virt pointers
let is i64 as MAX_USER_AS = 64;
let is [512]u8 as user_as_pml4s_raw;  // 64 * i64
let is i64 as user_as_count with mut = 0;

fn user_as_get(idx as i64) as i64 {
    let is *i64 as p = cast(*i64, &user_as_pml4s_raw);
    return p[idx];
}

fn user_as_set(idx as i64, v as i64) as void {
    let is *i64 as p = cast(*i64, &user_as_pml4s_raw);
    p[idx] = v;
}

// ============================================================
// Kernel PML4 sync — propagate new kernel PML4 entries to all user ASes
// ============================================================

fn kernel_pml4_sync(index as i64) as void {
    virq_save();
    let is *i64 as ksrc = cast(*i64, kas_pml4_virt);
    let is i64 as entry = ksrc[index];
    let is i64 as i with mut = 0;
    while (i < user_as_count) {
        let is i64 as upml4 = user_as_get(i);
        if (upml4 != 0) {
            let is *i64 as udst = cast(*i64, upml4);
            udst[index] = entry;
        }
        i = i + 1;
    }
    virq_restore();
}

// ============================================================
// ensure_table — create intermediate page table if missing
// Returns physical address of next-level table
// ============================================================

fn ensure_table(tphys as i64, tvirt as i64, idx as i64, flags as i64, is_kernel_as as i64) as i64 {
    let is i64 as pte = pte_read(tphys, idx);
    if (pte_present(pte) != 0) {
        return pte_addr(pte);
    }

    // Guard: user AS must not create page tables in kernel PML4 range
    if (is_kernel_as == 0) {
        if (tvirt != 0) {
            // This is a PML4-level insert (tvirt != 0 means we passed the PML4 virt)
            if (idx >= PML4_KERNEL_START) {
                pmm.panic("ensure_table: user AS creating kernel PT", 40);
            }
        }
    }

    let is i64 as new_phys = alloc_table_page(cast(i32, 0));
    pte_write(tphys, idx, new_phys | flags);

    // Sync if this is a new kernel PML4 entry
    if (is_kernel_as != 0) {
        if (tvirt != 0) {
            if (idx >= PML4_KERNEL_START) {
                if (idx <= PML4_KERNEL_END) {
                    kernel_pml4_sync(idx);
                }
            }
        }
    }
    return new_phys;
}

// ============================================================
// vmm_map_page — map 4KB page in a given PML4
// ============================================================

fn vmm_map_page(pml4_phys as i64, vaddr as i64, phys as i64, flags as i64) as i64 {
    let is i64 as p4 = pml4_index(vaddr);
    let is i64 as p3 = pdpt_index(vaddr);
    let is i64 as p2 = pd_index(vaddr);
    let is i64 as p1 = pt_index(vaddr);

    let is i64 as pml4_virt = pmm.phys_to_virt(pml4_phys);
    let is i64 as is_kas with mut = 0;
    if (pml4_phys == kas_pml4_phys) {
        is_kas = 1;
    }

    // Table flags: user-space addresses need PTE_USER at every level
    let is i64 as tflags with mut = PTE_TABLE;
    if (vaddr <= USER_SPACE_END) {
        tflags = PTE_TABLE_USER;
    }

    let is i64 as pdpt = ensure_table(pml4_phys, pml4_virt, p4, tflags, is_kas);
    let is i64 as pd = ensure_table(pdpt, 0, p3, tflags, is_kas);
    let is i64 as pt = ensure_table(pd, 0, p2, tflags, is_kas);

    // Check double-map
    let is i64 as existing = pte_read(pt, p1);
    if (pte_present(existing) != 0) {
        pmm.panic("vmm_map_page: already mapped", 28);
    }

    pte_write(pt, p1, (phys & PTE_ADDR_MASK) | flags);
    return 0;
}

// ============================================================
// vmm_unmap_page — unmap 4KB page, return old phys addr
// ============================================================

fn vmm_unmap_page(pml4_phys as i64, vaddr as i64) as i64 {
    let is i64 as pte4 = pte_read(pml4_phys, pml4_index(vaddr));
    if (pte_present(pte4) == 0) { return 0; }

    let is i64 as pte3 = pte_read(pte_addr(pte4), pdpt_index(vaddr));
    if (pte_present(pte3) == 0) { return 0; }

    let is i64 as pte2 = pte_read(pte_addr(pte3), pd_index(vaddr));
    if (pte_present(pte2) == 0) { return 0; }

    let is i64 as pt_phys = pte_addr(pte2);
    let is i64 as p1 = pt_index(vaddr);
    let is i64 as pte1 = pte_read(pt_phys, p1);
    if (pte_present(pte1) == 0) { return 0; }

    let is i64 as old_phys = pte_addr(pte1);
    pte_write(pt_phys, p1, 0);
    invlpg(vaddr);
    return old_phys;
}

// ============================================================
// vmm_remap_page — change flags without unmap
// ============================================================

fn vmm_remap_page(pml4_phys as i64, vaddr as i64, new_flags as i64) as void {
    let is i64 as pte4 = pte_read(pml4_phys, pml4_index(vaddr));
    if (pte_present(pte4) == 0) { pmm.panic("remap: pml4 absent", 18); }
    let is i64 as pte3 = pte_read(pte_addr(pte4), pdpt_index(vaddr));
    if (pte_present(pte3) == 0) { pmm.panic("remap: pdpt absent", 18); }
    let is i64 as pte2 = pte_read(pte_addr(pte3), pd_index(vaddr));
    if (pte_present(pte2) == 0) { pmm.panic("remap: pd absent", 16); }

    let is i64 as pt_phys = pte_addr(pte2);
    let is i64 as p1 = pt_index(vaddr);
    let is i64 as pte1 = pte_read(pt_phys, p1);
    if (pte_present(pte1) == 0) { pmm.panic("remap: pt absent", 16); }

    let is i64 as phys = pte_addr(pte1);
    pte_write(pt_phys, p1, phys | new_flags);
    invlpg(vaddr);
}

// ============================================================
// vmm_map_range — map N contiguous pages
// ============================================================

fn vmm_map_range(pml4_phys as i64, vaddr as i64, phys as i64, count as i64, flags as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < count) {
        let is i64 as r = vmm_map_page(pml4_phys,
            vaddr + i * pmm.PAGE_SIZE,
            phys + i * pmm.PAGE_SIZE,
            flags);
        if (r != 0) {
            // Rollback
            let is i64 as j with mut = 0;
            while (j < i) {
                vmm_unmap_page(pml4_phys, vaddr + j * pmm.PAGE_SIZE);
                j = j + 1;
            }
            return 0 - 1;
        }
        i = i + 1;
    }
    return 0;
}

// ============================================================
// virt_to_phys_walk — full page walk with huge page support
// ============================================================

fn virt_to_phys_walk(pml4_phys as i64, vaddr as i64) as i64 {
    let is i64 as pte4 = pte_read(pml4_phys, pml4_index(vaddr));
    if (pte_present(pte4) == 0) { return 0; }

    let is i64 as pte3 = pte_read(pte_addr(pte4), pdpt_index(vaddr));
    if (pte_present(pte3) == 0) { return 0; }
    if ((pte3 & PTE_HUGE) != 0) {
        return pte_addr(pte3) + (vaddr & 0x3FFFFFFF);
    }

    let is i64 as pte2 = pte_read(pte_addr(pte3), pd_index(vaddr));
    if (pte_present(pte2) == 0) { return 0; }
    if ((pte2 & PTE_HUGE) != 0) {
        return pte_addr(pte2) + (vaddr & 0x1FFFFF);
    }

    let is i64 as pte1 = pte_read(pte_addr(pte2), pt_index(vaddr));
    if (pte_present(pte1) == 0) { return 0; }
    return pte_addr(pte1) + (vaddr & 0xFFF);
}

// ============================================================
// User address space create/destroy/switch
// ============================================================

fn as_create() as i64 {
    let is i64 as pml4_phys = alloc_table_page(cast(i32, 0));
    let is i64 as pml4_virt = pmm.phys_to_virt(pml4_phys);

    // Lock: copy kernel entries + register atomically to prevent
    // race with kernel_pml4_sync (new entry could be missed otherwise)
    virq_save();

    // Copy kernel entries (256-511) from kernel AS
    let is *i64 as ksrc = cast(*i64, kas_pml4_virt);
    let is *i64 as udst = cast(*i64, pml4_virt);
    let is i64 as i with mut = PML4_KERNEL_START;
    while (i <= PML4_KERNEL_END) {
        udst[i] = ksrc[i];
        i = i + 1;
    }

    // Register for sync
    if (user_as_count < MAX_USER_AS) {
        user_as_set(user_as_count, pml4_virt);
        user_as_count = user_as_count + 1;
    }

    virq_restore();

    return pml4_phys;
}

// Validate that a physical page is actually a page table page before freeing
fn validate_pt_page(phys as i64) as void {
    let is i32 as pfn = pmm.phys_to_pfn(phys);
    let is *pmm.PageInfo as pi = pmm.pfn_to_pageinfo(pfn);
    if (cast(i64, pi) != 0) {
        let is i32 as usage = pmm.meta_get_usage(pi.meta);
        if (usage != cast(i32, pmm.USAGE_PAGE_TABLE)) {
            pmm.panic("as_free: not a PT page", 22);
        }
    }
}

fn free_pt_page(phys as i64) as void {
    validate_pt_page(phys);
    pmm.free_pages(pmm.phys_to_pfn(phys));
}

fn as_free_user_tables(pml4_phys as i64) as void {
    let is i64 as p4 with mut = 0;
    while (p4 < PML4_KERNEL_START) {
        let is i64 as pte4 = pte_read(pml4_phys, p4);
        if (pte_present(pte4) != 0) {
            let is i64 as pdpt_phys = pte_addr(pte4);
            let is i64 as p3 with mut = 0;
            while (p3 < 512) {
                let is i64 as pte3 = pte_read(pdpt_phys, p3);
                if (pte_present(pte3) != 0) {
                    if ((pte3 & PTE_HUGE) == 0) {
                        let is i64 as pd_phys = pte_addr(pte3);
                        let is i64 as p2 with mut = 0;
                        while (p2 < 512) {
                            let is i64 as pte2 = pte_read(pd_phys, p2);
                            if (pte_present(pte2) != 0) {
                                if ((pte2 & PTE_HUGE) == 0) {
                                    free_pt_page(pte_addr(pte2));
                                }
                            }
                            p2 = p2 + 1;
                        }
                        free_pt_page(pd_phys);
                    }
                }
                p3 = p3 + 1;
            }
            free_pt_page(pdpt_phys);
        }
        p4 = p4 + 1;
    }
}

fn as_destroy(pml4_phys as i64) as void {
    as_free_user_tables(pml4_phys);
    // Free PML4 page itself
    pmm.free_pages(pmm.phys_to_pfn(pml4_phys));

    // Remove from sync list
    let is i64 as pml4_virt = pmm.phys_to_virt(pml4_phys);
    let is i64 as i with mut = 0;
    while (i < user_as_count) {
        if (user_as_get(i) == pml4_virt) {
            // Shift remaining entries
            let is i64 as j with mut = i;
            while (j < user_as_count - 1) {
                user_as_set(j, user_as_get(j + 1));
                j = j + 1;
            }
            user_as_count = user_as_count - 1;
            return;
        }
        i = i + 1;
    }
}

fn as_switch(pml4_phys as i64) as void {
    write_cr3(pml4_phys);
}

// ============================================================
// User mapping helpers
// ============================================================

fn vmm_map_user_page(pml4_phys as i64, vaddr as i64, phys as i64, flags as i64) as i64 {
    if (vaddr > USER_SPACE_END) {
        pmm.panic("map_user: not user addr", 23);
    }
    return vmm_map_page(pml4_phys, vaddr, phys, flags);
}

fn vmm_alloc_user_page(pml4_phys as i64, vaddr as i64, flags as i64) as i64 {
    let is i32 as pfn = pmm.alloc_pages(
        pmm.ZONE_DMA32,
        pmm.ALLOC_ZERO | pmm.ALLOC_ALLOW_FALLBACK,
        cast(i32, 0), pmm.USAGE_KERNEL, cast(i32, 0)
    );
    if (pfn == pmm.PFN_NONE) { return 0 - 1; }

    let is i64 as r = vmm_map_user_page(pml4_phys, vaddr, pmm.pfn_to_phys(pfn), flags);
    if (r != 0) {
        pmm.free_pages(pfn);
        return 0 - 1;
    }
    return 0;
}

// ============================================================
// kvalloc — virtual kernel allocator
// ============================================================

// Bitmap: 262144 pages / 8 bits = 32768 bytes
let is [32768]u8 as kv_bitmap;

// Range tracking: sorted array of {vaddr, pages, bm_start, bm_count, pfns_ptr}
// Each entry = 40 bytes (5 x i64)
let is i64 as KV_MAX_RANGES  = 256;
let is [10240]u8 as kv_ranges_raw;  // 256 * 40
let is i64 as kv_range_count with mut = 0;

fn kvr_get(idx as i64, field as i64) as i64 {
    let is *i64 as p = cast(*i64, cast(i64, &kv_ranges_raw) + idx * 40);
    return p[field];
}

fn kvr_set(idx as i64, field as i64, v as i64) as void {
    let is *i64 as p = cast(*i64, cast(i64, &kv_ranges_raw) + idx * 40);
    p[field] = v;
}
// Fields: 0=vaddr, 1=pages, 2=bm_start, 3=bm_count, 4=pfns_ptr

// Bitmap operations
fn bm_test(bit as i64) as i64 {
    let is *u8 as bm = cast(*u8, &kv_bitmap);
    let is i64 as byte_idx = bit >> 3;
    let is i64 as bit_idx = bit & 7;
    return (cast(i64, bm[byte_idx]) >> bit_idx) & 1;
}

fn bm_set(start as i64, count as i64) as void {
    let is *u8 as bm = cast(*u8, &kv_bitmap);
    let is i64 as i with mut = start;
    while (i < start + count) {
        let is i64 as byte_idx = i >> 3;
        let is i64 as bit_idx = i & 7;
        bm[byte_idx] = cast(u8, cast(i64, bm[byte_idx]) | (1 << bit_idx));
        i = i + 1;
    }
}

fn bm_clear(start as i64, count as i64) as void {
    let is *u8 as bm = cast(*u8, &kv_bitmap);
    let is i64 as i with mut = start;
    while (i < start + count) {
        let is i64 as byte_idx = i >> 3;
        let is i64 as bit_idx = i & 7;
        let is i64 as mask = (1 << bit_idx) ^ 0xFF;
        bm[byte_idx] = cast(u8, cast(i64, bm[byte_idx]) & mask);
        i = i + 1;
    }
}

fn bm_find_free(count as i64) as i64 {
    let is i64 as run_start with mut = 0 - 1;
    let is i64 as run_len with mut = 0;
    let is i64 as i with mut = 0;
    while (i < KVALLOC_PAGES) {
        if (bm_test(i) == 0) {
            if (run_len == 0) {
                run_start = i;
            }
            run_len = run_len + 1;
            if (run_len == count) {
                return run_start;
            }
        } else {
            run_len = 0;
        }
        i = i + 1;
    }
    return 0 - 1;
}

// Range insert (sorted by vaddr)
fn kvr_insert(vaddr as i64, pages as i64, bm_start as i64, bm_count as i64, pfns as i64) as void {
    if (kv_range_count >= KV_MAX_RANGES) {
        pmm.panic("kvalloc: range table full", 25);
    }
    // Find insertion point
    let is i64 as pos with mut = kv_range_count;
    let is i64 as i with mut = 0;
    while (i < kv_range_count) {
        if (kvr_get(i, 0) > vaddr) {
            pos = i;
            i = kv_range_count; // break
        }
        i = i + 1;
    }
    // Shift entries after pos
    let is i64 as j with mut = kv_range_count;
    while (j > pos) {
        let is i64 as k with mut = 0;
        while (k < 5) {
            kvr_set(j, k, kvr_get(j - 1, k));
            k = k + 1;
        }
        j = j - 1;
    }
    kvr_set(pos, 0, vaddr);
    kvr_set(pos, 1, pages);
    kvr_set(pos, 2, bm_start);
    kvr_set(pos, 3, bm_count);
    kvr_set(pos, 4, pfns);
    kv_range_count = kv_range_count + 1;
}

// Range find by vaddr
fn kvr_find(vaddr as i64) as i64 {
    let is i64 as i with mut = 0;
    while (i < kv_range_count) {
        if (kvr_get(i, 0) == vaddr) {
            return i;
        }
        i = i + 1;
    }
    return 0 - 1;
}

// Range remove by index
fn kvr_remove(idx as i64) as void {
    let is i64 as i with mut = idx;
    while (i < kv_range_count - 1) {
        let is i64 as k with mut = 0;
        while (k < 5) {
            kvr_set(i, k, kvr_get(i + 1, k));
            k = k + 1;
        }
        i = i + 1;
    }
    kv_range_count = kv_range_count - 1;
}

fn kvalloc(size as i64, flags as i64) as i64 {
    if (size == 0) { return 0; }

    let is i64 as data_pages = pmm.align_up(size, pmm.PAGE_SIZE) / pmm.PAGE_SIZE;
    let is i64 as total_pages = data_pages + 2;  // guard + data + guard

    // Find virtual range
    let is i64 as bm_start = bm_find_free(total_pages);
    if (bm_start < 0) { return 0; }

    bm_set(bm_start, total_pages);

    let is i64 as data_vaddr = KVALLOC_BASE + (bm_start + 1) * pmm.PAGE_SIZE;

    // Allocate PFN array via kmalloc
    let is i64 as pfn_array = heap.kmalloc(data_pages * 8, cast(i32, 0));
    if (pfn_array == 0) {
        bm_clear(bm_start, total_pages);
        return 0;
    }

    // Allocate physical pages
    let is *i64 as pfns = cast(*i64, pfn_array);
    let is i64 as i with mut = 0;
    while (i < data_pages) {
        let is i32 as pfn = pmm.alloc_pages(
            pmm.ZONE_DMA32, pmm.ALLOC_ALLOW_FALLBACK,
            cast(i32, 0), pmm.USAGE_KERNEL, cast(i32, 0)
        );
        if (pfn == pmm.PFN_NONE) {
            // Rollback
            let is i64 as j with mut = 0;
            while (j < i) {
                pmm.free_pages(cast(i32, pfns[j]));
                j = j + 1;
            }
            heap.kfree(pfn_array);
            bm_clear(bm_start, total_pages);
            return 0;
        }
        pfns[i] = cast(i64, pfn);
        i = i + 1;
    }

    // Map data pages (guards stay unmapped)
    i = 0;
    while (i < data_pages) {
        vmm_map_page(kas_pml4_phys,
            data_vaddr + i * pmm.PAGE_SIZE,
            pmm.pfn_to_phys(cast(i32, pfns[i])),
            KMAP_DATA);
        i = i + 1;
    }

    flush_tlb_range(data_vaddr, data_pages);

    // Register range
    kvr_insert(data_vaddr, data_pages, bm_start, total_pages, pfn_array);

    // Zero if requested
    if ((flags & cast(i64, pmm.ALLOC_ZERO)) != 0) {
        let is *u8 as p = cast(*u8, data_vaddr);
        let is i64 as z with mut = 0;
        let is i64 as zlen = data_pages * pmm.PAGE_SIZE;
        while (z < zlen) {
            p[z] = 0;
            z = z + 1;
        }
    }

    return data_vaddr;
}

fn kvfree(ptr as i64) as void {
    if (ptr == 0) { return; }

    let is i64 as ridx = kvr_find(ptr);
    if (ridx < 0) {
        pmm.panic("kvfree: unknown ptr", 19);
    }

    let is i64 as data_pages = kvr_get(ridx, 1);
    let is i64 as bm_start = kvr_get(ridx, 2);
    let is i64 as bm_count = kvr_get(ridx, 3);
    let is i64 as pfn_array = kvr_get(ridx, 4);
    let is *i64 as pfns = cast(*i64, pfn_array);

    kvr_remove(ridx);

    // Unmap data pages
    let is i64 as i with mut = 0;
    while (i < data_pages) {
        vmm_unmap_page(kas_pml4_phys, ptr + i * pmm.PAGE_SIZE);
        i = i + 1;
    }

    flush_tlb_range(ptr, data_pages);

    // Free physical pages
    i = 0;
    while (i < data_pages) {
        pmm.free_pages(cast(i32, pfns[i]));
        i = i + 1;
    }

    // Free virtual range
    bm_clear(bm_start, bm_count);

    // Free metadata
    heap.kfree(pfn_array);
}

// ============================================================
// DMA allocator
// ============================================================

// DmaAddr: vaddr(i64), phys(i64), order(i32 in i64 slot)
// Returned as 3 values packed into globals (Caustic has no multi-return)
let is i64 as dma_result_vaddr with mut = 0;
let is i64 as dma_result_phys with mut = 0;
let is i64 as dma_result_order with mut = 0;

fn ceil_log2(v as i64) as i32 {
    if (v <= 1) { return cast(i32, 0); }
    let is i32 as n with mut = 0;
    let is i64 as x with mut = v - 1;
    while (x > 0) {
        n = n + cast(i32, 1);
        x = x >> 1;
    }
    return n;
}

fn dma_alloc(size as i64) as void {
    dma_result_vaddr = 0;
    dma_result_phys = 0;
    dma_result_order = 0;

    if (size == 0) { return; }

    let is i64 as pages = pmm.align_up(size, pmm.PAGE_SIZE) / pmm.PAGE_SIZE;
    let is i32 as order = ceil_log2(pages);

    let is i32 as pfn = pmm.alloc_pages(
        pmm.ZONE_DMA32,
        pmm.ALLOC_DMA32_ONLY | pmm.ALLOC_ZERO,
        order, pmm.USAGE_KERNEL, cast(i32, 0)
    );
    if (pfn == pmm.PFN_NONE) { return; }

    let is i64 as phys = pmm.pfn_to_phys(pfn);
    dma_result_vaddr = pmm.phys_to_virt(phys);
    dma_result_phys = phys;
    dma_result_order = cast(i64, order);
}

fn dma_free(vaddr as i64) as void {
    if (vaddr == 0) { return; }
    let is i64 as phys = vaddr - pmm.hhdm;
    pmm.free_pages(pmm.phys_to_pfn(phys));
}

// ============================================================
// Init
// ============================================================

fn init() as void {
    serial.println("vmm: init", 9);

    // Init constants
    PTE_ADDR_MASK = 0x000FFFFFFFFFF000;
    PTE_NX = 1 << 63;
    PTE_TABLE = PTE_PRESENT | PTE_WRITE | PTE_NX;
    PTE_TABLE_USER = PTE_PRESENT | PTE_WRITE | PTE_USER | PTE_NX;
    KMAP_DATA = PTE_PRESENT | PTE_WRITE | PTE_NX;
    USER_SPACE_END = 0x00007FFFFFFFFFFF;

    // Read Limine's PML4
    let is i64 as limine_pml4 = read_cr3() & PTE_ADDR_MASK;
    serial.print("  limine cr3=", 13);
    idt.print_hex(limine_pml4);
    serial.println("", 0);

    // Allocate kernel PML4
    kas_pml4_phys = alloc_table_page(cast(i32, 0));
    kas_pml4_virt = pmm.phys_to_virt(kas_pml4_phys);

    // Deep clone Limine's kernel page table tree (entries 256-511).
    // Limine's PT pages may reside in bootloader-reclaimable memory
    // which the PMM treats as usable. If we only copy PML4 entries
    // (shallow clone), the underlying PDPT/PD/PT pages could be
    // overwritten by buddy allocations. We must allocate our own
    // copies of the entire tree.
    let is *i64 as lsrc = cast(*i64, pmm.phys_to_virt(limine_pml4));
    let is *i64 as kdst = cast(*i64, kas_pml4_virt);
    let is i64 as i with mut = PML4_KERNEL_START;
    while (i <= PML4_KERNEL_END) {
        let is i64 as pml4e = lsrc[i];
        if (pte_present(pml4e) != 0) {
            // Clone PDPT
            let is i64 as old_pdpt = pte_addr(pml4e);
            let is i64 as new_pdpt = alloc_table_page(cast(i32, 0));
            let is *i64 as osrc = cast(*i64, pmm.phys_to_virt(old_pdpt));
            let is *i64 as ndst = cast(*i64, pmm.phys_to_virt(new_pdpt));
            let is i64 as j with mut = 0;
            while (j < 512) {
                let is i64 as pdpte = osrc[j];
                if (pte_present(pdpte) != 0) {
                    if ((pdpte & PTE_HUGE) != 0) {
                        // 1GB huge page — keep as-is (points to data, not a table)
                        ndst[j] = pdpte;
                    } else {
                        // Clone PD
                        let is i64 as old_pd = pte_addr(pdpte);
                        let is i64 as new_pd = alloc_table_page(cast(i32, 0));
                        let is *i64 as pd_src = cast(*i64, pmm.phys_to_virt(old_pd));
                        let is *i64 as pd_dst = cast(*i64, pmm.phys_to_virt(new_pd));
                        let is i64 as k with mut = 0;
                        while (k < 512) {
                            let is i64 as pde = pd_src[k];
                            if (pte_present(pde) != 0) {
                                if ((pde & PTE_HUGE) != 0) {
                                    // 2MB huge page — keep as-is
                                    pd_dst[k] = pde;
                                } else {
                                    // Clone PT
                                    let is i64 as old_pt = pte_addr(pde);
                                    let is i64 as new_pt = alloc_table_page(cast(i32, 0));
                                    let is *i64 as pt_src = cast(*i64, pmm.phys_to_virt(old_pt));
                                    let is *i64 as pt_dst = cast(*i64, pmm.phys_to_virt(new_pt));
                                    let is i64 as m with mut = 0;
                                    while (m < 512) {
                                        pt_dst[m] = pt_src[m];
                                        m = m + 1;
                                    }
                                    // Rewrite PD entry to point to cloned PT
                                    pd_dst[k] = new_pt | (pde & 0xFFF);
                                }
                            }
                            k = k + 1;
                        }
                        // Rewrite PDPT entry to point to cloned PD
                        ndst[j] = new_pd | (pdpte & 0xFFF);
                    }
                }
                j = j + 1;
            }
            // Rewrite PML4 entry to point to cloned PDPT
            kdst[i] = new_pdpt | (pml4e & 0xFFF);
        }
        i = i + 1;
    }

    // Switch to our fully-cloned PML4
    write_cr3(kas_pml4_phys);
    serial.print("  kernel cr3=", 13);
    idt.print_hex(kas_pml4_phys);
    serial.println("", 0);

    // Zero kvalloc bitmap
    let is *u8 as bm = cast(*u8, &kv_bitmap);
    i = 0;
    while (i < 32768) {
        bm[i] = 0;
        i = i + 1;
    }

    // Self-tests
    // Test 1: page walk
    let is i64 as tv = cast(i64, &kas_pml4_phys);
    let is i64 as tp = virt_to_phys_walk(kas_pml4_phys, tv);
    serial.print("  walk: ", 8);
    idt.print_hex(tv);
    serial.print("->", 2);
    idt.print_hex(tp);
    serial.println("", 0);

    // Test 2: kvalloc
    let is i64 as kv1 = kvalloc(4096, cast(i64, pmm.ALLOC_ZERO));
    if (kv1 != 0) {
        let is *i64 as kvp = cast(*i64, kv1);
        kvp[0] = 0xCAFEBABE;
        if (kvp[0] == 0xCAFEBABE) {
            serial.println("  kvalloc test: ok", 18);
        } else {
            serial.println("  kvalloc test: FAIL", 20);
        }
        kvfree(kv1);
    }

    // Test 3: DMA alloc
    dma_alloc(4096);
    if (dma_result_vaddr != 0) {
        serial.print("  dma phys=", 11);
        idt.print_hex(dma_result_phys);
        serial.println(" ok", 3);
        dma_free(dma_result_vaddr);
    }

    serial.println("vmm: ready", 10);
}
