// platform.cst — machine-level primitives that drivers should use instead of
// reaching into specific chip modules (IOAPIC, PIC, LAPIC) directly.
//
// Today the backend is the IOAPIC (x86_64 modern systems). When PIC-only
// machines, MSI/MSI-X, or a different arch land, only this file changes —
// drivers keep calling set_irq_route / mask_irq / unmask_irq unchanged.

use "ioapic.cst" as ioapic;

// Route a hardware IRQ line to a CPU interrupt vector on a specific CPU
// (destination expressed as LAPIC ID for the current backend). On
// success the entry is unmasked and ready to deliver.
fn set_irq_route(hw_irq as i64, vector as i64, dest_cpu as i64) as void {
    ioapic.set_redirection(hw_irq, vector, dest_cpu);
}

// Mask a hardware IRQ line so it stops delivering until unmasked.
fn mask_irq(hw_irq as i64) as void {
    ioapic.mask(hw_irq);
}
