// dummybus.cst — end-to-end integration test for the driver framework.
//
// Declares a synthetic BusType, a single BusInstance, and a single Driver.
// Exercises every framework path: bus_type_register, bus_instance_register,
// bus_register_driver, enumerate_instance (creating a child Device), and
// the Phase-2 match + probe sequence.

use "driver.cst" as driver;
use "serial.cst" as serial;
use "util.cst" as util;

// Statically-allocated storage. Zero-initialized by virtue of living in .bss.
let is driver.BusType as dummy_bt;
let is driver.BusInstance as dummy_bi;
let is driver.Driver as dummy_drv;

fn dummy_match(bt as *driver.BusType, dev as *driver.Device, drv as *driver.Driver) as i32 {
    // Synthetic bus matches anything. Real buses inspect drv.match_spec.
    return 1;
}

fn dummy_enumerate(bi as *driver.BusInstance) as void {
    serial.println("dummybus: enumerate", 19);
    let is *driver.Device as d = driver.device_alloc(sizeof(driver.Device), 8);
    if (cast(i64, d) == 0) {
        serial.println("dummybus: device_alloc failed", 29);
        return;
    }
    // Name: "dummy-dev"
    d.name[0] = cast(u8, 100);
    d.name[1] = cast(u8, 117);
    d.name[2] = cast(u8, 109);
    d.name[3] = cast(u8, 109);
    d.name[4] = cast(u8, 121);
    d.name[5] = cast(u8, 45);
    d.name[6] = cast(u8, 100);
    d.name[7] = cast(u8, 101);
    d.name[8] = cast(u8, 118);
    d.state = driver.STATE_UNINITIALIZED;
    let is i32 as rc = driver.device_register(d, cast(*driver.Device, bi));
    if (rc != driver.OK) {
        serial.println("dummybus: device_register failed", 32);
    }
}

let is i32 as mmio_smoke_done with mut = 0;
let is i32 as irq_smoke_done with mut = 0;
let is i64 as irq_hit_count with mut = 0;

fn dummy_irq_handler(dev as *driver.Device, ctx as *u8) as i32 {
    irq_hit_count = irq_hit_count + 1;
    return 0;  // HANDLED
}

fn dummy_probe(dev as *driver.Device) as i32 {
    serial.println("dummy_driver: probe matched OK", 30);

    if (mmio_smoke_done == 0) {
        mmio_smoke_done = 1;
        serial.println("smoke: calling mmio_map...", 26);
        let is *u8 as lapic_virt with mut = cast(*u8, 0);
        let is i32 as rc = driver.mmio_map(dev, cast(u64, 0xFEE00000),
                                           cast(u64, 4096), cast(u32, 0),
                                           &lapic_virt);
        serial.print("smoke: mmio_map rc=", 19);
        util.print_num(cast(i64, rc));
        serial.println("", 0);
        if (rc == driver.OK) {
            serial.print("smoke: lapic vaddr=", 19);
            util.print_hex(cast(i64, lapic_virt));
            serial.println("", 0);
            let is *u32 as id_reg = cast(*u32, cast(i64, lapic_virt) + 0x20);
            let is u32 as raw = *id_reg;
            serial.print("smoke: lapic id=", 16);
            util.print_num(cast(i64, raw) >> 24);
            serial.println("", 0);
        }
    }

    if (irq_smoke_done == 0) {
        irq_smoke_done = 1;
        let is i32 as rc = driver.irq_register(dev, cast(u32, 48), cast(i32, 0),
                                               fn_ptr(dummy_irq_handler),
                                               cast(*u8, 0));
        serial.print("smoke: irq_register rc=", 23);
        util.print_num(cast(i64, rc));
        serial.println("", 0);
        if (rc == driver.OK) {
            serial.println("smoke: firing int 0x30...", 25);
            // caustic-as does not assemble `int N` — emit raw bytes.
            asm(".byte 0xCD, 0x30\n");
            serial.println("smoke: int 0x30 returned", 24);
            serial.print("smoke: irq_hit_count=", 21);
            util.print_num(irq_hit_count);
            serial.println("", 0);
        }
    }

    return driver.OK;
}

fn dummy_remove(dev as *driver.Device) as void {
}

// Called from _kernel_start during Phase 1. Populates the three static
// entries and registers them with the framework.
fn register() as void {
    // BusType: name "dummy"
    dummy_bt.name[0] = cast(u8, 100);
    dummy_bt.name[1] = cast(u8, 117);
    dummy_bt.name[2] = cast(u8, 109);
    dummy_bt.name[3] = cast(u8, 109);
    dummy_bt.name[4] = cast(u8, 121);
    dummy_bt.match_fn = fn_ptr(dummy_match);
    dummy_bt.enumerate_instance = fn_ptr(dummy_enumerate);
    driver.bus_type_register(&dummy_bt);

    // BusInstance: caller presets base.bus_type (spec fix #15) before register.
    dummy_bi.base.bus_type = &dummy_bt;
    dummy_bi.base.state = driver.STATE_UNINITIALIZED;
    dummy_bi.base.name[0] = cast(u8, 100);
    dummy_bi.base.name[1] = cast(u8, 117);
    dummy_bi.base.name[2] = cast(u8, 109);
    dummy_bi.base.name[3] = cast(u8, 109);
    dummy_bi.base.name[4] = cast(u8, 121);
    dummy_bi.base.name[5] = cast(u8, 48);    // '0'
    driver.bus_instance_register(&dummy_bi, driver.get_root());

    // Driver: name "dummydrv", priority 50
    dummy_drv.name[0] = cast(u8, 100);
    dummy_drv.name[1] = cast(u8, 117);
    dummy_drv.name[2] = cast(u8, 109);
    dummy_drv.name[3] = cast(u8, 109);
    dummy_drv.name[4] = cast(u8, 121);
    dummy_drv.name[5] = cast(u8, 100);
    dummy_drv.name[6] = cast(u8, 114);
    dummy_drv.name[7] = cast(u8, 118);
    dummy_drv.priority = 50;
    dummy_drv.probe = fn_ptr(dummy_probe);
    dummy_drv.remove = fn_ptr(dummy_remove);
    driver.bus_register_driver(&dummy_bt, &dummy_drv);

    serial.println("dummybus: registered", 20);
}
