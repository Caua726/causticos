// timer.cst — Monotonic clock + timer abstraction
// PIT used for early boot + LAPIC calibration, LAPIC for runtime

use "serial.cst" as serial;
use "port.cst" as port;

// ============================================================
// State
// ============================================================

let is i64 as tick_count with mut = 0;
let is i64 as lapic_ticks with mut = 0;
let is i64 as NS_PER_TICK        = 1000000;    // 1ms per PIT tick

// need_resched flag (checked on IRQ return)
let is i64 as need_resched with mut = 0;

// LAPIC mode flag
let is i64 as using_lapic with mut = 0;

// ============================================================
// Monotonic clock
// ============================================================

fn current_time_ns() as i64 {
    return tick_count * NS_PER_TICK;
}

fn get_ticks() as i64 {
    return tick_count;
}

// ============================================================
// PIT tick handler (called from IRQ 0)
// ============================================================

fn on_tick() as void {
    tick_count = tick_count + 1;
}

// ============================================================
// LAPIC tick handler (called from LAPIC timer vector)
// ============================================================

fn on_lapic_tick() as void {
    tick_count = tick_count + 1;
    lapic_ticks = lapic_ticks + 1;
}

// ============================================================
// PIT init (early boot, before LAPIC calibration)
// ============================================================

fn init() as void {
    serial.println("timer: init", 11);

    let is i64 as divisor = 1193182 / 1000;
    port.outb(0x43, 0x34);
    port.outb(0x40, divisor & 0xFF);
    port.outb(0x40, (divisor >> 8) & 0xFF);

    // divisor and hz logged by caller
    serial.println("timer: ready", 12);
}
