// timer.cst — PIT timer + monotonic clock
// PIT channel 0 in rate generator mode (mode 2) for periodic ticks

use "serial.cst" as serial;
use "port.cst" as port;

// ============================================================
// PIT constants
// ============================================================

let is i64 as PIT_BASE_HZ    = 1193182;    // PIT oscillator frequency
let is i64 as PIT_CH0_DATA   = 0x40;       // channel 0 data port
let is i64 as PIT_CMD         = 0x43;       // command port

// Target tick rate: 1000 Hz (1 ms per tick)
let is i64 as TICK_HZ         = 1000;
let is i64 as NS_PER_TICK     = 1000000;    // 1ms = 1,000,000 ns

// ============================================================
// State
// ============================================================

let is i64 as tick_count with mut = 0;
let is i64 as ns_elapsed with mut = 0;

// need_resched flag (checked on IRQ return)
let is i64 as need_resched with mut = 0;

// ============================================================
// current_time_ns — monotonic nanosecond clock
// ============================================================

fn current_time_ns() as i64 {
    return tick_count * NS_PER_TICK;
}

fn get_ticks() as i64 {
    return tick_count;
}

// ============================================================
// Timer tick handler — called from idt.irq_handler for IRQ 0
// ============================================================

fn on_tick() as void {
    tick_count = tick_count + 1;
    ns_elapsed = tick_count * NS_PER_TICK;

    // Don't blindly set need_resched — the scheduler's on_timer_tick
    // will check quantum expiration and set it only when needed.
    // Callers (sched.on_timer_tick) are responsible for setting need_resched.
}

// ============================================================
// Init — program PIT channel 0
// ============================================================

fn init() as void {
    serial.println("timer: init", 11);

    // PIT divisor for desired frequency
    // divisor = PIT_BASE_HZ / TICK_HZ
    let is i64 as divisor = PIT_BASE_HZ / TICK_HZ;

    // Command: channel 0, lobyte/hibyte, mode 2 (rate generator), binary
    // 0x34 = 00 11 010 0
    //   channel 0 (00)
    //   access lobyte/hibyte (11)
    //   mode 2 (010)
    //   binary (0)
    port.outb(PIT_CMD, 0x34);

    // Send divisor low byte then high byte
    port.outb(PIT_CH0_DATA, divisor & 0xFF);
    port.outb(PIT_CH0_DATA, (divisor >> 8) & 0xFF);

    // divisor and hz logged by caller

    serial.println("timer: ready", 12);
}
