// pci.cst — PCI bus integration with the driver framework.
//
// Mechanism #1 config-space access + per-function Device allocation.
// A single BusInstance is registered for bus 0; PCI-to-PCI bridges
// enumerate their secondary bus inline, attaching children to the
// bridge PciDevice rather than spawning new BusInstances.

use "port.cst" as port;
use "driver.cst" as driver;
use "serial.cst" as serial;
use "util.cst" as util;

let is i64 as CONFIG_ADDRESS = 0xCF8;
let is i64 as CONFIG_DATA    = 0xCFC;

fn pci_addr(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    let is i64 as a with mut = 0x80000000;
    a = a | (cast(i64, bus)  << 16);
    a = a | (cast(i64, dev)  << 11);
    a = a | (cast(i64, func) << 8);
    a = a | (cast(i64, off)  & 0xFC);
    return a;
}

fn pci_config_read32(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    port.outl(CONFIG_ADDRESS, pci_addr(bus, dev, func, off));
    return port.inl(CONFIG_DATA);
}

fn pci_config_read16(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    let is i64 as dw = pci_config_read32(bus, dev, func, off);
    return (dw >> (cast(i64, (off & 2)) * 8)) & 0xFFFF;
}

fn pci_config_read8(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    let is i64 as dw = pci_config_read32(bus, dev, func, off);
    return (dw >> (cast(i64, (off & 3)) * 8)) & 0xFF;
}

fn pci_config_write32(bus as i32, dev as i32, func as i32, off as i32, val as i64) as void {
    port.outl(CONFIG_ADDRESS, pci_addr(bus, dev, func, off));
    port.outl(CONFIG_DATA, val);
}

struct PciMatchSpec {
    vendor as i64;
    device as i64;
}

// All scalar fields are i64 — mixed-width struct layouts hit a codegen
// issue that caused adjacent fields to overlap.
//
// bar0 holds the decoded base address: low 32 bits for 32-bit BARs, full
// 64 bits with the high dword from offset 0x14 merged in for 64-bit BARs.
// Type/prefetch bits are masked off. Additional BARs (1,2,3,4,5) are not
// stored — add them when a driver actually needs one.
struct PciDevice {
    base as driver.Device;
    bus as i64;
    dev as i64;
    func as i64;
    vendor as i64;
    device_id as i64;
    class_code as i64;
    subclass as i64;
    prog_if as i64;
    revision as i64;
    header_type as i64;
    bar0 as i64;
}

let is driver.BusType     as pci_bt;
let is driver.BusInstance as pci_bi0;

fn pci_match(bt as *driver.BusType, dev as *driver.Device, drv as *driver.Driver) as i32 {
    if (cast(i64, drv.match_spec) == 0) { return 0; }
    let is *PciMatchSpec as spec = cast(*PciMatchSpec, drv.match_spec);
    let is *PciDevice as pd = cast(*PciDevice, dev);
    if (spec.vendor != pd.vendor) { return 0; }
    if (spec.device != pd.device_id) { return 0; }
    return 1;
}

// Walks one PCI bus, registering every present function as a child of `parent`.
// Bridges (class=0x06, subclass=0x04) recurse into their secondary bus, placing
// children under the bridge PciDevice so the framework's DFS probe visits them
// in topological order.
fn enumerate_bus(parent as *driver.Device, bus as i32) as void {
    let is i32 as d with mut = cast(i32, 0);
    while (d < 32) {
        let is i64 as ven = pci_config_read16(bus, d, cast(i32, 0), cast(i32, 0));
        if (ven != 0xFFFF) {
            let is i64 as ht0 = pci_config_read8(bus, d, cast(i32, 0), cast(i32, 0x0E));
            let is i32 as nfn with mut = cast(i32, 1);
            if ((ht0 & 0x80) != 0) { nfn = cast(i32, 8); }
            let is i32 as f with mut = cast(i32, 0);
            while (f < nfn) {
                let is i64 as fven = pci_config_read16(bus, d, f, cast(i32, 0));
                if (fven != 0xFFFF) {
                    enumerate_function(parent, bus, d, f, fven);
                }
                f = f + cast(i32, 1);
            }
        }
        d = d + cast(i32, 1);
    }
}

fn enumerate_function(parent as *driver.Device, bus as i32, d as i32, f as i32, fven as i64) as void {
    let is i64 as pd_addr = cast(i64, driver.device_alloc(sizeof(PciDevice), 8));
    if (pd_addr == 0) {
        serial.println("pci: device_alloc failed", 24);
        return;
    }
    let is *PciDevice as pd = cast(*PciDevice, pd_addr);

    let is i64 as fdev = pci_config_read16(bus, d, f, cast(i32, 2));
    let is i64 as cls  = pci_config_read32(bus, d, f, cast(i32, 8));
    let is i64 as ht   = pci_config_read8(bus, d, f, cast(i32, 0x0E));
    let is i64 as cc   = (cls >> 24) & 0xFF;
    let is i64 as sc   = (cls >> 16) & 0xFF;
    let is i64 as pif  = (cls >> 8)  & 0xFF;
    let is i64 as rev  = cls & 0xFF;

    pd.bus         = cast(i64, bus);
    pd.dev         = cast(i64, d);
    pd.func        = cast(i64, f);
    pd.vendor      = fven;
    pd.device_id   = fdev;
    pd.revision    = rev;
    pd.prog_if     = pif;
    pd.subclass    = sc;
    pd.class_code  = cc;
    pd.header_type = ht & 0x7F;

    // Both Type 0 and Type 1 headers have BAR0 at offset 0x10.
    let is i64 as bar0_raw = pci_config_read32(bus, d, f, cast(i32, 0x10));
    if ((bar0_raw & 0x1) != 0) {
        // I/O BAR: low 2 bits are type, rest is port base.
        pd.bar0 = bar0_raw & 0xFFFFFFFC;
    } else {
        // Memory BAR: low 4 bits are type+prefetch. Type bits [2:1]:
        //   0b10 = 64-bit BAR, next slot holds high 32 bits.
        let is i64 as base_lo = bar0_raw & 0xFFFFFFF0;
        if (((bar0_raw >> 1) & 0x3) == 0x2) {
            let is i64 as bar1_raw = pci_config_read32(bus, d, f, cast(i32, 0x14));
            pd.bar0 = base_lo | (bar1_raw << 32);
        } else {
            pd.bar0 = base_lo;
        }
    }

    pd.base.name[0] = cast(u8, 112); // 'p'
    pd.base.name[1] = cast(u8, 99);  // 'c'
    pd.base.name[2] = cast(u8, 105); // 'i'
    pd.base.state = driver.STATE_UNINITIALIZED;
    pd.base.bus_type = &pci_bt;

    let is *driver.Device as as_dev = cast(*driver.Device, pd);
    let is i32 as rc = driver.device_register(as_dev, parent);
    if (rc != driver.OK) {
        serial.println("pci: device_register failed", 27);
        return;
    }

    serial.print("pci: ", 5);
    util.print_num(cast(i64, bus));
    serial.putc(58);
    util.print_num(cast(i64, d));
    serial.putc(46);
    util.print_num(cast(i64, f));
    serial.print(" ven=", 5);
    util.print_hex(fven);
    serial.print(" dev=", 5);
    util.print_hex(fdev);
    serial.print(" class=", 7);
    util.print_hex(cc);
    serial.putc(58);
    util.print_hex(sc);
    serial.println("", 0);

    // PCI-to-PCI bridge: walk secondary bus under this device.
    if (cc == 0x06 && sc == 0x04) {
        let is i64 as sec = pci_config_read8(bus, d, f, cast(i32, 0x19));
        enumerate_bus(as_dev, cast(i32, sec));
    }
}

fn pci_enumerate(bi as *driver.BusInstance) as void {
    serial.println("pci: enumerate bus 0", 20);
    enumerate_bus(cast(*driver.Device, bi), cast(i32, 0));
}

fn register() as void {
    pci_bt.name[0] = cast(u8, 112); // 'p'
    pci_bt.name[1] = cast(u8, 99);  // 'c'
    pci_bt.name[2] = cast(u8, 105); // 'i'
    pci_bt.match_fn = fn_ptr(pci_match);
    pci_bt.enumerate_instance = fn_ptr(pci_enumerate);
    driver.bus_type_register(&pci_bt);

    pci_bi0.base.bus_type = &pci_bt;
    pci_bi0.base.state = driver.STATE_UNINITIALIZED;
    pci_bi0.base.name[0] = cast(u8, 112);
    pci_bi0.base.name[1] = cast(u8, 99);
    pci_bi0.base.name[2] = cast(u8, 105);
    pci_bi0.base.name[3] = cast(u8, 48); // '0'
    driver.bus_instance_register(&pci_bi0, driver.get_root());

    serial.println("pci: registered", 15);
}
