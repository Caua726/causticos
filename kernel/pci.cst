// pci.cst — PCI config-space access (Mechanism #1, port I/O via 0xCF8/0xCFC).
//
// Exposes pci_config_read8/16/32 and pci_config_write32, plus a
// pci_probe_bus0 diagnostic that walks bus 0 and prints any devices found.
// Later steps will add PciDevice struct, bus enumeration that feeds the
// driver framework, and PciMatchSpec for drivers.

use "port.cst" as port;
use "serial.cst" as serial;
use "util.cst" as util;

let is i64 as CONFIG_ADDRESS = 0xCF8;
let is i64 as CONFIG_DATA    = 0xCFC;

// Compose a 32-bit CONFIG_ADDRESS value. Offset is truncated to its
// dword-aligned bits (the mechanism reads/writes dwords at a time).
fn pci_addr(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    let is i64 as a with mut = 0x80000000;
    a = a | (cast(i64, bus)  << 16);
    a = a | (cast(i64, dev)  << 11);
    a = a | (cast(i64, func) << 8);
    a = a | (cast(i64, off)  & 0xFC);
    return a;
}

fn pci_config_read32(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    port.outl(CONFIG_ADDRESS, pci_addr(bus, dev, func, off));
    return port.inl(CONFIG_DATA) & 0xFFFFFFFF;
}

fn pci_config_read16(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    let is i64 as dw = pci_config_read32(bus, dev, func, off);
    let is i64 as shift = cast(i64, (off & 2)) * 8;
    return (dw >> shift) & 0xFFFF;
}

fn pci_config_read8(bus as i32, dev as i32, func as i32, off as i32) as i64 {
    let is i64 as dw = pci_config_read32(bus, dev, func, off);
    let is i64 as shift = cast(i64, (off & 3)) * 8;
    return (dw >> shift) & 0xFF;
}

fn pci_config_write32(bus as i32, dev as i32, func as i32, off as i32, val as i64) as void {
    port.outl(CONFIG_ADDRESS, pci_addr(bus, dev, func, off));
    port.outl(CONFIG_DATA, val & 0xFFFFFFFF);
}

// Convenience accessors.
fn pci_vendor_id(bus as i32, dev as i32, func as i32) as i64 {
    return pci_config_read16(bus, dev, func, cast(i32, 0));
}

fn pci_device_id(bus as i32, dev as i32, func as i32) as i64 {
    return pci_config_read16(bus, dev, func, cast(i32, 2));
}

// Returns header_type. Bit 7 set means multi-function device.
fn pci_header_type(bus as i32, dev as i32, func as i32) as i64 {
    return pci_config_read8(bus, dev, func, cast(i32, 0x0E));
}

// Diagnostic: walk bus 0, print vendor/device/class for each present
// function. Does not touch the framework — just proves config reads work.
fn pci_probe_bus0() as void {
    serial.println("pci: probing bus 0", 18);
    let is i32 as d with mut = cast(i32, 0);
    while (d < 32) {
        let is i64 as ven = pci_vendor_id(cast(i32, 0), d, cast(i32, 0));
        if (ven != 0xFFFF) {
            let is i32 as f with mut = cast(i32, 0);
            let is i64 as ht = pci_header_type(cast(i32, 0), d, cast(i32, 0));
            let is i64 as nfn with mut = 1;
            if ((ht & 0x80) != 0) { nfn = 8; }
            while (cast(i64, f) < nfn) {
                let is i64 as fven = pci_vendor_id(cast(i32, 0), d, f);
                if (fven != 0xFFFF) {
                    let is i64 as fdev = pci_device_id(cast(i32, 0), d, f);
                    let is i64 as cls  = pci_config_read32(cast(i32, 0), d, f, cast(i32, 8));
                    let is i64 as cc   = (cls >> 24) & 0xFF;
                    let is i64 as sc   = (cls >> 16) & 0xFF;
                    let is i64 as pif  = (cls >> 8)  & 0xFF;
                    serial.print("  00:", 5);
                    util.print_num(cast(i64, d));
                    serial.putc(46);                // '.'
                    util.print_num(cast(i64, f));
                    serial.print("  ven=", 6);
                    util.print_hex(fven);
                    serial.print(" dev=", 5);
                    util.print_hex(fdev);
                    serial.print(" class=", 7);
                    util.print_hex(cc);
                    serial.putc(58);                // ':'
                    util.print_hex(sc);
                    serial.putc(58);
                    util.print_hex(pif);
                    serial.println("", 0);
                }
                f = f + cast(i32, 1);
            }
        }
        d = d + cast(i32, 1);
    }
}
