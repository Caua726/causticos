// sched.cst — Full scheduler: EEVDF, deadline (EDF+CBS), anti-abuse, preemption
// Based on causticos_sched_spec_v1
//
// Lock ordering (§17):
//   deadline_tree.lock < qos_band.lock < cpu_runqueue.lock < global_capabilities.lock
//   V1 single-CPU: all protected by IRQ disable. Locks become spinlocks for SMP.
//
// Thread allocation: kcache for structs + open-addressing hash table for
// TID→Thread* lookup. Hash table grows dynamically (doubles at 75% load).
// Thread count limited only by available memory.

use "serial.cst" as serial;
use "pmm.cst" as pmm;
use "heap.cst" as heap;
use "timer.cst" as timer;
use "util.cst" as util;
use "rbtree.cst" as rb;
use "lapic.cst" as lapic;

// ============================================================
// Constants
// ============================================================

// Thread states (§15)
let is i64 as THREAD_RUNNING   = 1;
let is i64 as THREAD_RUNNABLE  = 2;
let is i64 as THREAD_SLEEPING  = 3;
let is i64 as THREAD_SUSPENDED = 4;
let is i64 as THREAD_DEAD      = 5;

// Scheduling classes (§4)
let is i64 as SCHED_CLASS_DEADLINE = 0;
let is i64 as SCHED_CLASS_QOS     = 1;
let is i64 as SCHED_CLASS_IDLE    = 2;

// QoS bands (§4.2.1)
let is i64 as QOS_INPUT        = 0;
let is i64 as QOS_RENDER       = 1;
let is i64 as QOS_ACTIVE       = 2;
let is i64 as QOS_NORMAL       = 3;
let is i64 as QOS_BATCH        = 4;
let is i64 as QOS_LAZY         = 5;
let is i64 as NUM_QOS_BANDS    = 6;

// QoS budget enforcement window (§7.2): 1 second in ns
let is i64 as QOS_WINDOW_NS    = 1000000000;

// EEVDF (§5)
let is i64 as BASE_WEIGHT      = 1024;
let is i64 as DEFAULT_SLICE_NS = 5000000;
let is i64 as SLEEPER_BONUS_NS with mut = 2500000;  // configurable (§5.4)

// Quantum (§13) — mutable, configurable
let is i64 as MIN_QUANTUM_NS   = 1000000;
let is i64 as MAX_QUANTUM_NS   = 100000000;
let is i64 as quantum_ns with mut = 5000000;

// Deadline (§6) — configurable
let is i64 as MAX_DL_UTIL_PCT with mut = 70;

// Capabilities (§8)
let is i64 as CAP_SCHED_REALTIME = 1;
let is i64 as CAP_SCHED_INPUT    = 2;
let is i64 as CAP_SCHED_RENDER   = 4;
let is i64 as CAP_SCHED_AFFINITY = 8;

// Kernel stack
let is i64 as KSTACK_SIZE      = 8192;
let is i64 as MAX_THREADS      = 64;

// FPU state size (fxsave = 512 bytes)
let is i64 as FPU_STATE_SIZE   = 512;

// ============================================================
// Thread struct — 384 bytes
// ============================================================
// 0    tid              i64
// 8    state            i64
// 16   sched_class      i64
// 24   qos_band         i64
// 32   weight           i64
// 40   slice_ns         i64
// 48   vruntime         i64
// 56   virtual_deadline i64
// 64   kstack_top       i64   (saved RSP)
// 72   kstack_base      i64
// 80   entry_fn         i64
// 88   total_runtime_ns i64
// 96   next_tid         i64   (run list / deadline list)
// 104  prev_tid         i64
// 112  lag              i64
// 120  voluntary_sw     i64
// 128  forced_sw        i64
// --- Deadline class (§6) ---
// 136  dl_runtime_ns    i64
// 144  dl_period_ns     i64
// 152  dl_deadline_ns   i64
// 160  dl_budget_left   i64
// 168  dl_period_start  i64
// 176  dl_abs_deadline  i64
// --- Anti-abuse (§7) ---
// 184  cpu_used_window  i64
// 192  window_start_ns  i64
// 200  band_violations  i64
// 208  band_below_count i64
// 216  original_qos_band i64
// 224  capabilities     i64
// --- FPU (§14.2) ---
// 232  fpu_dirty        i64
// 240  fpu_state_addr   i64   (pointer to 512-byte fxsave area, 16-aligned)
// --- Process link ---
// 248  process_ptr      i64   (ptr to owning Process)
// 256  reserved         128 bytes
// Total: 384

let is i64 as THREAD_SIZE = 384;
// Dynamic thread allocation via kcache
let is i64 as thread_cache with mut = 0;

// TID → Thread* hash table (open addressing, power-of-2 size)
// Each slot: [tid (i64), ptr (i64)] = 16 bytes. tid = -1 means empty.
let is i64 as tid_ht_buf with mut = 0;     // kmalloc'd buffer
let is i64 as tid_ht_cap with mut = 0;     // capacity (power of 2)
let is i64 as tid_ht_count with mut = 0;   // entries used
let is i64 as TID_HT_EMPTY = 0 - 1;       // sentinel for empty slot

let is i64 as thread_count with mut = 0;
let is i64 as next_tid with mut = 0;

fn tid_ht_init(cap as i64) as void {
    let is i64 as size = cap * 16;
    tid_ht_buf = heap.kmalloc(size, pmm.ALLOC_ZERO);
    if (tid_ht_buf == 0) { pmm.panic("tid_ht alloc fail", 17); }
    tid_ht_cap = cap;
    tid_ht_count = 0;
    // Mark all slots empty
    let is i64 as i with mut = 0;
    while (i < cap) {
        let is *i64 as slot = cast(*i64, tid_ht_buf + i * 16);
        slot[0] = TID_HT_EMPTY;
        i = i + 1;
    }
}

fn tid_ht_grow() as void {
    let is i64 as old_buf = tid_ht_buf;
    let is i64 as old_cap = tid_ht_cap;
    let is i64 as new_cap = old_cap * 2;
    let is i64 as new_buf = heap.kmalloc(new_cap * 16, pmm.ALLOC_ZERO);
    if (new_buf == 0) { pmm.panic("tid_ht grow fail", 16); }

    // Mark new slots empty
    let is i64 as i with mut = 0;
    while (i < new_cap) {
        let is *i64 as slot = cast(*i64, new_buf + i * 16);
        slot[0] = TID_HT_EMPTY;
        i = i + 1;
    }

    // Rehash old entries
    tid_ht_buf = new_buf;
    tid_ht_cap = new_cap;
    tid_ht_count = 0;
    i = 0;
    while (i < old_cap) {
        let is *i64 as slot = cast(*i64, old_buf + i * 16);
        if (slot[0] != TID_HT_EMPTY) {
            tid_set_ptr(slot[0], slot[1]);
        }
        i = i + 1;
    }
    heap.kfree(old_buf);
}

fn tid_set_ptr(tid as i64, ptr as i64) as void {
    // Grow if > 75% full
    if (tid_ht_count * 4 >= tid_ht_cap * 3) {
        tid_ht_grow();
    }
    let is i64 as mask = tid_ht_cap - 1;
    let is i64 as idx with mut = tid & mask;
    let is i64 as done with mut = 0;
    while (done == 0) {
        let is *i64 as slot = cast(*i64, tid_ht_buf + idx * 16);
        if (slot[0] == TID_HT_EMPTY) {
            slot[0] = tid;
            slot[1] = ptr;
            tid_ht_count = tid_ht_count + 1;
            done = 1;
        } else {
            if (slot[0] == tid) {
                slot[1] = ptr;  // update existing
                done = 1;
            } else {
                idx = (idx + 1) & mask;  // linear probe
            }
        }
    }
}

fn thread_ptr(tid as i64) as i64 {
    let is i64 as mask = tid_ht_cap - 1;
    let is i64 as idx with mut = tid & mask;
    let is i64 as checked with mut = 0;
    while (checked < tid_ht_cap) {
        let is *i64 as slot = cast(*i64, tid_ht_buf + idx * 16);
        if (slot[0] == TID_HT_EMPTY) { return 0; }  // not found
        if (slot[0] == tid) { return slot[1]; }
        idx = (idx + 1) & mask;
        checked = checked + 1;
    }
    return 0;  // not found
}

fn thr_get(tid as i64, off as i64) as i64 {
    let is *i64 as p = cast(*i64, thread_ptr(tid) + off);
    return p[0];
}

fn thr_set(tid as i64, off as i64, v as i64) as void {
    let is *i64 as p = cast(*i64, thread_ptr(tid) + off);
    p[0] = v;
}

fn thr_state(tid as i64) as i64         { return thr_get(tid, 8); }
fn thr_class(tid as i64) as i64         { return thr_get(tid, 16); }
fn thr_band(tid as i64) as i64          { return thr_get(tid, 24); }
fn thr_weight(tid as i64) as i64        { return thr_get(tid, 32); }
fn thr_slice(tid as i64) as i64         { return thr_get(tid, 40); }
fn thr_vruntime(tid as i64) as i64      { return thr_get(tid, 48); }
fn thr_vdeadline(tid as i64) as i64     { return thr_get(tid, 56); }
fn thr_kstack_top(tid as i64) as i64    { return thr_get(tid, 64); }
fn thr_entry(tid as i64) as i64         { return thr_get(tid, 80); }
fn thr_runtime(tid as i64) as i64       { return thr_get(tid, 88); }
fn thr_next(tid as i64) as i64          { return thr_get(tid, 96); }
fn thr_prev(tid as i64) as i64          { return thr_get(tid, 104); }
fn thr_lag(tid as i64) as i64           { return thr_get(tid, 112); }
fn thr_dl_budget(tid as i64) as i64     { return thr_get(tid, 160); }
fn thr_dl_abs_dl(tid as i64) as i64     { return thr_get(tid, 176); }
fn thr_caps(tid as i64) as i64          { return thr_get(tid, 224); }

// ============================================================
// Per-band data
// ============================================================

// ============================================================
// CpuRunqueue (§9) — per-CPU scheduling state
// V1: single instance. SMP: array indexed by cpu_id.
// ============================================================
// Layout (512 bytes):
// 0    cpu_id           i64
// 8    dl_root          i64   (RB tree root)
// 16   dl_count         i64
// 24   current_tid      i64
// 32   current_start_ns i64
// 40   idle_tid         i64
// 48   nr_running       i64
// 56   nr_switches      i64
// 64   fpu_owner_tid    i64
// 72   band_roots[6]    48 bytes (6 * i64, RB tree roots)
// 120  band_counts[6]   48 bytes
// 168  band_min_vrt[6]  48 bytes
// 216  band_budgets[6]  192 bytes (6 * 4 * i64)
// 408  reserved         104 bytes
// Total: 512

let is i64 as RQ_SIZE = 512;
let is [512]u8 as cpu_rq_raw;    // single CPU runqueue

fn rq_ptr() as i64 { return cast(i64, &cpu_rq_raw); }

fn rq_get(off as i64) as i64 {
    let is *i64 as p = cast(*i64, rq_ptr() + off);
    return p[0];
}

fn rq_set(off as i64, v as i64) as void {
    let is *i64 as p = cast(*i64, rq_ptr() + off);
    p[0] = v;
}

// Named accessors
fn dl_root() as i64          { return rq_get(8); }
fn dl_root_ptr() as i64      { return rq_ptr() + 8; }
fn dl_count() as i64         { return rq_get(16); }
fn dl_set_count(v as i64) as void { rq_set(16, v); }

fn current_tid() as i64      { return rq_get(24); }
fn set_current_tid(v as i64) as void { rq_set(24, v); }
fn current_start_ns() as i64 { return rq_get(32); }
fn set_current_start_ns(v as i64) as void { rq_set(32, v); }
fn idle_tid() as i64         { return rq_get(40); }
fn set_idle_tid(v as i64) as void { rq_set(40, v); }
fn nr_running() as i64       { return rq_get(48); }
fn set_nr_running(v as i64) as void { rq_set(48, v); }
fn nr_switches() as i64      { return rq_get(56); }
fn set_nr_switches(v as i64) as void { rq_set(56, v); }
fn fpu_owner_tid() as i64    { return rq_get(64); }
fn set_fpu_owner_tid(v as i64) as void { rq_set(64, v); }

// Per-band accessors (within runqueue)
fn band_root_ptr(b as i64) as i64 { return rq_ptr() + 72 + b * 8; }
fn band_root(b as i64) as i64 {
    let is *i64 as p = cast(*i64, rq_ptr() + 72);
    return p[b];
}
fn band_count(b as i64) as i64 {
    let is *i64 as p = cast(*i64, rq_ptr() + 120);
    return p[b];
}
fn band_set_count(b as i64, v as i64) as void {
    let is *i64 as p = cast(*i64, rq_ptr() + 120);
    p[b] = v;
}
fn band_min_vruntime(b as i64) as i64 {
    let is *i64 as p = cast(*i64, rq_ptr() + 168);
    return p[b];
}
fn band_set_min_vruntime(b as i64, v as i64) as void {
    let is *i64 as p = cast(*i64, rq_ptr() + 168);
    p[b] = v;
}

// Band budgets (within runqueue, 4 i64 per band)
fn bb_get(band as i64, field as i64) as i64 {
    let is *i64 as p = cast(*i64, rq_ptr() + 216 + band * 32);
    return p[field];
}
fn bb_set(band as i64, field as i64, v as i64) as void {
    let is *i64 as p = cast(*i64, rq_ptr() + 216 + band * 32);
    p[field] = v;
}

// ============================================================
// Global scheduling state (not per-CPU)
// ============================================================

let is i64 as sched_active with mut = 0;

let is i64 as switch_rsp with mut = 0;
let is i64 as ctx_old_rsp_ptr with mut = 0;
let is i64 as ctx_new_rsp with mut = 0;

// Preemption control (§11.5)
let is i64 as preempt_count with mut = 0;

fn band_weight(b as i64) as i64 {
    if (b == QOS_BATCH) { return 512; }
    if (b == QOS_LAZY)  { return 256; }
    return BASE_WEIGHT;
}

// ============================================================
// Preempt disable/enable (§11.5)
// ============================================================

fn preempt_disable() as void {
    preempt_count = preempt_count + 1;
}

fn preempt_enable() as void {
    preempt_count = preempt_count - 1;
    if (preempt_count == 0) {
        if (pmm.in_irq_context == 0) {
            if (timer.need_resched != 0) {
                schedule();
            }
        }
    }
}

fn cond_resched() as void {
    if (preempt_count > 0) { return; }
    if (pmm.in_irq_context != 0) { return; }  // never schedule from IRQ context
    if (timer.need_resched != 0) {
        schedule();
    }
}

// ============================================================
// Run list operations (QoS bands, sorted by virtual_deadline)
// ============================================================

// RB tree insert/remove for QoS bands (keyed by virtual_deadline)
fn runlist_insert(band as i64, tid as i64) as void {
    rb.rb_insert(band_root_ptr(band), thr_vdeadline(tid), tid);
    band_set_count(band, band_count(band) + 1);
}

fn runlist_remove(band as i64, tid as i64) as void {
    let is i64 as node = rb.rb_find_by_val(band_root(band), tid);
    if (node != 0) {
        rb.rb_delete(band_root_ptr(band), node);
    }
    band_set_count(band, band_count(band) - 1);
}

// ============================================================
// Deadline list (sorted by dl_abs_deadline, ascending) — §6.5
// Reuses next_tid/prev_tid fields (a thread is in ONE list at a time)
// ============================================================

// RB tree insert/remove for deadline class (keyed by dl_abs_deadline)
fn dl_insert(tid as i64) as void {
    rb.rb_insert(dl_root_ptr(), thr_dl_abs_dl(tid), tid);
    dl_set_count(dl_count() + 1);
}

fn dl_remove(tid as i64) as void {
    let is i64 as node = rb.rb_find_by_val(dl_root(), tid);
    if (node != 0) {
        rb.rb_delete(dl_root_ptr(), node);
    }
    dl_set_count(dl_count() - 1);
}

// ============================================================
// EEVDF helpers
// ============================================================

fn update_band_min_vruntime(band as i64) as void {
    let is i64 as lm = rb.rb_leftmost(band_root(band));
    if (lm != 0) {
        let is i64 as tid = rb.nd_val(lm);
        let is i64 as hv = thr_vruntime(tid);
        if (hv > band_min_vruntime(band)) {
            band_set_min_vruntime(band, hv);
        }
    }
}

fn update_vruntime(tid as i64, elapsed_ns as i64) as void {
    let is i64 as w = thr_weight(tid);
    let is i64 as delta = elapsed_ns * BASE_WEIGHT / w;
    let is i64 as new_vrt = thr_vruntime(tid) + delta;
    thr_set(tid, 48, new_vrt);
    thr_set(tid, 56, new_vrt + (thr_slice(tid) * BASE_WEIGHT / w));
    thr_set(tid, 88, thr_runtime(tid) + elapsed_ns);
    let is i64 as lag = band_min_vruntime(thr_band(tid)) - new_vrt;
    thr_set(tid, 112, lag);
}

// ============================================================
// Deadline class: admission test (§6.1)
// ============================================================

fn dl_total_utilization() as i64 {
    // Returns utilization as percentage (walk all deadline threads)
    let is i64 as total with mut = 0;
    let is i64 as n with mut = rb.rb_leftmost(dl_root());
    while (n != 0) {
        let is i64 as tid = rb.nd_val(n);
        let is i64 as rt = thr_get(tid, 136);
        let is i64 as pd = thr_get(tid, 144);
        if (pd > 0) {
            total = total + (rt * 100 / pd);
        }
        n = rb.rb_next(n);
    }
    return total;
}

fn sched_set_deadline(tid as i64, runtime_ns as i64, period_ns as i64, deadline_ns as i64) as i64 {
    // Check capability
    if ((thr_caps(tid) & CAP_SCHED_REALTIME) == 0) {
        return 0 - 1;  // EPERM
    }
    if (runtime_ns > deadline_ns) { return 0 - 2; }  // EINVAL
    if (deadline_ns > period_ns)  { return 0 - 2; }

    // Admission test
    let is i64 as new_util = runtime_ns * 100 / period_ns;
    let is i64 as total = dl_total_utilization() + new_util;
    if (total > MAX_DL_UTIL_PCT) {
        return 0 - 3;  // EBUSY
    }

    // Remove from QoS band if currently there
    if (thr_class(tid) == SCHED_CLASS_QOS) {
        if (thr_state(tid) == THREAD_RUNNABLE) {
            runlist_remove(thr_band(tid), tid);
        }
    }

    thr_set(tid, 16, SCHED_CLASS_DEADLINE);
    thr_set(tid, 136, runtime_ns);
    thr_set(tid, 144, period_ns);
    thr_set(tid, 152, deadline_ns);
    thr_set(tid, 160, runtime_ns);                     // budget_left = full
    let is i64 as now = timer.current_time_ns();
    thr_set(tid, 168, now);                            // period_start
    thr_set(tid, 176, now + deadline_ns);              // abs_deadline

    if (thr_state(tid) == THREAD_RUNNABLE) {
        dl_insert(tid);
    }

    return 0;
}

// CBS budget enforcement (§6.3)
fn dl_account(tid as i64, elapsed_ns as i64) as void {
    let is i64 as budget = thr_dl_budget(tid) - elapsed_ns;
    thr_set(tid, 160, budget);
    thr_set(tid, 88, thr_runtime(tid) + elapsed_ns);

    if (budget <= 0) {
        // Budget exhausted — suspend until next period
        thr_set(tid, 8, THREAD_SUSPENDED);
        dl_remove(tid);
        // Period replenishment will be checked on timer tick
    }
}

// Period replenishment (§6.4)
fn dl_check_replenish() as void {
    let is i64 as now = timer.current_time_ns();
    let is i64 as tid with mut = 0;
    while (tid < next_tid) {
        if (thr_class(tid) == SCHED_CLASS_DEADLINE) {
            if (thr_state(tid) == THREAD_SUSPENDED) {
                let is i64 as period_start = thr_get(tid, 168);
                let is i64 as period_ns = thr_get(tid, 144);
                if (now >= period_start + period_ns) {
                    // New period: replenish budget
                    thr_set(tid, 168, now);                          // new period_start
                    thr_set(tid, 160, thr_get(tid, 136));            // budget = runtime
                    thr_set(tid, 176, now + thr_get(tid, 152));      // new abs_deadline
                    thr_set(tid, 8, THREAD_RUNNABLE);
                    dl_insert(tid);
                    set_nr_running(nr_running() + 1);
                    timer.need_resched = 1;
                }
            }
        }
        tid = tid + 1;
    }
}

// ============================================================
// Anti-abuse: budget enforcement (§7.3)
// ============================================================

fn qos_budget_check(tid as i64, elapsed_ns as i64) as void {
    let is i64 as band = thr_band(tid);
    let is i64 as max_pct = bb_get(band, 0);
    if (max_pct >= 100) { return; }  // no enforcement for this band

    // Accumulate CPU time
    thr_set(tid, 184, thr_get(tid, 184) + elapsed_ns);

    let is i64 as now = timer.current_time_ns();
    let is i64 as window_start = thr_get(tid, 192);
    let is i64 as window_ns = bb_get(band, 1);
    let is i64 as window_age = now - window_start;

    if (window_age >= window_ns) {
        let is i64 as cpu_used = thr_get(tid, 184);
        let is i64 as cpu_pct = cpu_used * 100 / window_age;

        if (cpu_pct > max_pct) {
            let is i64 as violations = thr_get(tid, 200) + 1;
            thr_set(tid, 200, violations);
            thr_set(tid, 208, 0);  // reset below_count
            let is i64 as demo_thresh = bb_get(band, 3);
            if (demo_thresh > 0) {
                if (violations >= demo_thresh) {
                    demote_thread(tid);
                }
            }
        } else {
            let is i64 as below = thr_get(tid, 208) + 1;
            thr_set(tid, 208, below);
            thr_set(tid, 200, 0);  // reset violations
            let is i64 as promo_thresh = bb_get(band, 2);
            if (promo_thresh > 0) {
                if (below >= promo_thresh) {
                    let is i64 as orig = thr_get(tid, 216);
                    if (band > orig) {
                        promote_thread(tid);
                    }
                }
            }
        }
        // Reset window
        thr_set(tid, 184, 0);
        thr_set(tid, 192, now);
    }
}

fn demote_thread(tid as i64) as void {
    let is i64 as band = thr_band(tid);
    if (band >= QOS_LAZY) { return; }
    let is i64 as new_band = band + 1;
    // If in runlist, move
    if (thr_state(tid) == THREAD_RUNNABLE) {
        runlist_remove(band, tid);
    }
    thr_set(tid, 24, new_band);
    thr_set(tid, 32, band_weight(new_band));
    thr_set(tid, 200, 0);
    thr_set(tid, 208, 0);
    if (thr_state(tid) == THREAD_RUNNABLE) {
        runlist_insert(new_band, tid);
    }
    serial.print("demote tid=", 11);
    util.print_num(tid);
    serial.println("", 0);
}

fn promote_thread(tid as i64) as void {
    let is i64 as band = thr_band(tid);
    let is i64 as orig = thr_get(tid, 216);
    if (band <= orig) { return; }
    let is i64 as new_band = band - 1;
    if (thr_state(tid) == THREAD_RUNNABLE) {
        runlist_remove(band, tid);
    }
    thr_set(tid, 24, new_band);
    thr_set(tid, 32, band_weight(new_band));
    thr_set(tid, 200, 0);
    thr_set(tid, 208, 0);
    if (thr_state(tid) == THREAD_RUNNABLE) {
        runlist_insert(new_band, tid);
    }
}

// ============================================================
// Capability check for band declaration (§7.1, §8)
// ============================================================

fn sched_set_qos(tid as i64, requested_band as i64) as i64 {
    if (requested_band == QOS_INPUT) {
        if ((thr_caps(tid) & CAP_SCHED_INPUT) == 0) { return 0 - 1; }
    }
    if (requested_band == QOS_RENDER) {
        if ((thr_caps(tid) & CAP_SCHED_RENDER) == 0) { return 0 - 1; }
    }
    thr_set(tid, 24, requested_band);
    thr_set(tid, 216, requested_band);  // original_qos_band
    thr_set(tid, 32, band_weight(requested_band));
    return 0;
}

// ============================================================
// FPU lazy save (§14.2)
// ============================================================

// Set TS bit in CR0 (causes #NM on FPU use)
fn cr0_set_ts() as void {
    // mov rax, cr0 = 0x0F 0x20 0xC0
    asm(".byte 0x0F, 0x20, 0xC0\n");
    asm("or rax, 8\n");           // bit 3 = TS
    // mov cr0, rax = 0x0F 0x22 0xC0
    asm(".byte 0x0F, 0x22, 0xC0\n");
}

// Clear TS bit in CR0
fn cr0_clear_ts() as void {
    // clts = 0x0F 0x06
    asm(".byte 0x0F, 0x06\n");
}

// Save FPU state (fxsave [rdi])
fn fpu_save(addr as i64) as void {
    // fxsave [rdi] = 0x0F 0xAE 0x07
    asm(".byte 0x0F, 0xAE, 0x07\n");
}

// Restore FPU state (fxrstor [rdi])
fn fpu_restore(addr as i64) as void {
    // fxrstor [rdi] = 0x0F 0xAE, 0x0F
    asm(".byte 0x0F, 0xAE, 0x0F\n");
}

// Called by #NM exception handler when a thread uses FPU for first time
fn handle_nm_fault() as void {
    cr0_clear_ts();

    let is i64 as cur = current_tid();
    if (cur < 0) { return; }

    // Save previous owner's FPU state
    if (fpu_owner_tid() >= 0) {
        if (fpu_owner_tid() != cur) {
            let is i64 as prev_fpu_addr = thr_get(fpu_owner_tid(), 240);
            if (prev_fpu_addr != 0) {
                fpu_save(prev_fpu_addr);
            }
        }
    }

    // Restore current thread's FPU state
    let is i64 as cur_fpu_addr = thr_get(cur, 240);
    if (cur_fpu_addr != 0) {
        fpu_restore(cur_fpu_addr);
    }

    set_fpu_owner_tid(cur);
    thr_set(cur, 232, 1);  // fpu_dirty = 1
}

// ============================================================
// Thread creation
// ============================================================

fn create_thread(entry as i64, band as i64) as i64 {

    let is i64 as tid = next_tid;
    next_tid = next_tid + 1;

    // Allocate thread struct via kcache (dynamic)
    let is i64 as tptr with mut = 0;
    if (thread_cache != 0) {
        tptr = heap.kcache_alloc(thread_cache, cast(i32, 0));
    } else {
        tptr = heap.kmalloc(THREAD_SIZE, pmm.ALLOC_ZERO);
    }
    if (tptr == 0) { pmm.panic("thread alloc fail", 17); }
    tid_set_ptr(tid, tptr);

    let is *u8 as tp = cast(*u8, tptr);
    let is i64 as z with mut = 0;
    while (z < THREAD_SIZE) { tp[z] = 0; z = z + 1; }

    // Kernel stack
    let is i32 as stack_pfn = pmm.alloc_pages(
        pmm.ZONE_DMA32, pmm.ALLOC_ZERO | pmm.ALLOC_ALLOW_FALLBACK,
        cast(i32, 1), pmm.USAGE_KERNEL, cast(i32, 0)
    );
    if (stack_pfn == pmm.PFN_NONE) { pmm.panic("stack alloc fail", 16); }

    let is i64 as stack_base = pmm.phys_to_virt(pmm.pfn_to_phys(stack_pfn));
    let is i64 as stack_top = stack_base + KSTACK_SIZE;

    // Fake stack frame
    let is *i64 as sf = cast(*i64, stack_top - 56);
    asm("lea rax, [rip+_kernel_sched_cst_thread_entry_trampoline]\n");
    asm("lea rbx, [rip+_kernel_sched_cst_switch_rsp]\n");
    asm("mov QWORD PTR [rbx], rax\n");
    sf[0] = switch_rsp;
    sf[1] = 0; sf[2] = 0; sf[3] = 0; sf[4] = 0; sf[5] = 0; sf[6] = 0;

    // FPU state area (16-byte aligned, allocated via kmalloc)
    let is i64 as fpu_addr = heap.kmalloc(FPU_STATE_SIZE, pmm.ALLOC_ZERO);

    // EEVDF: start at band.min_vruntime
    let is i64 as w = band_weight(band);
    let is i64 as mvrt = band_min_vruntime(band);
    let is i64 as vd = mvrt + (DEFAULT_SLICE_NS * BASE_WEIGHT / w);
    let is i64 as now = timer.current_time_ns();

    thr_set(tid, 0, tid);
    thr_set(tid, 8, THREAD_RUNNABLE);
    thr_set(tid, 16, SCHED_CLASS_QOS);
    thr_set(tid, 24, band);
    thr_set(tid, 32, w);
    thr_set(tid, 40, DEFAULT_SLICE_NS);
    thr_set(tid, 48, mvrt);
    thr_set(tid, 56, vd);
    thr_set(tid, 64, stack_top - 56);
    thr_set(tid, 72, stack_base);
    thr_set(tid, 80, entry);
    thr_set(tid, 96, 0 - 1);
    thr_set(tid, 104, 0 - 1);
    thr_set(tid, 112, 0);             // lag
    thr_set(tid, 192, now);           // window_start_ns
    thr_set(tid, 216, band);          // original_qos_band
    thr_set(tid, 240, fpu_addr);      // fpu_state_addr

    runlist_insert(band, tid);
    set_nr_running(nr_running() + 1);
    thread_count = thread_count + 1;

    return tid;
}

// ============================================================
// Sleep / Wakeup (§5.4)
// ============================================================

fn sleep_thread(tid as i64) as void {
    if (thr_state(tid) != THREAD_RUNNING) { return; }
    thr_set(tid, 8, THREAD_SLEEPING);
    schedule();
}

fn wakeup_thread(tid as i64) as void {
    if (thr_state(tid) != THREAD_SLEEPING) { return; }

    let is i64 as band = thr_band(tid);
    let is i64 as w = thr_weight(tid);
    let is i64 as mvrt = band_min_vruntime(band);
    let is i64 as old_vrt = thr_vruntime(tid);
    let is i64 as adjusted = mvrt - SLEEPER_BONUS_NS;
    let is i64 as new_vrt with mut = old_vrt;
    if (adjusted > old_vrt) { new_vrt = adjusted; }

    thr_set(tid, 48, new_vrt);
    thr_set(tid, 112, 0);
    thr_set(tid, 56, new_vrt + (thr_slice(tid) * BASE_WEIGHT / w));
    thr_set(tid, 8, THREAD_RUNNABLE);

    if (thr_class(tid) == SCHED_CLASS_DEADLINE) {
        dl_insert(tid);
    } else {
        runlist_insert(band, tid);
    }
    set_nr_running(nr_running() + 1);

    if (current_tid() >= 0) {
        if (thr_class(current_tid()) == SCHED_CLASS_IDLE) { timer.need_resched = 1; }
        else {
            if (thr_class(tid) == SCHED_CLASS_DEADLINE) { timer.need_resched = 1; }
            else {
                if (thr_class(current_tid()) == SCHED_CLASS_QOS) {
                    if (band < thr_band(current_tid())) { timer.need_resched = 1; }
                }
            }
        }
    }
}

fn suspend_thread(tid as i64) as void {
    if (thr_state(tid) != THREAD_RUNNING) { return; }
    thr_set(tid, 8, THREAD_SUSPENDED);
    schedule();
}

fn resume_thread(tid as i64) as void {
    if (thr_state(tid) != THREAD_SUSPENDED) { return; }
    thr_set(tid, 8, THREAD_RUNNABLE);
    let is i64 as band = thr_band(tid);
    if (thr_class(tid) == SCHED_CLASS_DEADLINE) { dl_insert(tid); }
    else { runlist_insert(band, tid); }
    set_nr_running(nr_running() + 1);
}

// ============================================================
// Thread entry trampoline
// ============================================================

let is i64 as trampoline_entry with mut = 0;

fn thread_entry_trampoline() as void {
    asm(".byte 0xFB\n");  // sti
    trampoline_entry = thr_entry(current_tid());
    asm("lea rax, [rip+_kernel_sched_cst_trampoline_entry]\n");
    asm("mov rax, QWORD PTR [rax]\n");
    asm("call rax\n");
    thr_set(current_tid(), 8, THREAD_DEAD);
    set_nr_running(nr_running() - 1);
    schedule();
    while (1 == 1) { asm(".byte 0xF4\n"); }
}

// ============================================================
// pick_next (§10)
// ============================================================

fn pick_next_deadline() as i64 {
    // Walk RB tree from leftmost (earliest deadline) — §6.2
    let is i64 as n with mut = rb.rb_leftmost(dl_root());
    while (n != 0) {
        let is i64 as tid = rb.nd_val(n);
        if (thr_dl_budget(tid) > 0) { return tid; }
        n = rb.rb_next(n);
    }
    return 0 - 1;
}

fn pick_next_in_band(band as i64) as i64 {
    // Walk RB tree from leftmost (smallest virtual_deadline) — §5.2
    // Find first eligible thread (lag >= 0)
    let is i64 as n with mut = rb.rb_leftmost(band_root(band));
    while (n != 0) {
        let is i64 as tid = rb.nd_val(n);
        if (thr_lag(tid) >= 0) { return tid; }
        n = rb.rb_next(n);
    }

    // No eligible thread — advance min_vruntime to re-eligibilize (§5.2)
    // All threads have negative lag. Advance band clock to smallest vruntime,
    // making that thread eligible. This is mathematically correct — not a mask.
    let is i64 as lm = rb.rb_leftmost(band_root(band));
    if (lm != 0) {
        let is i64 as tid = rb.nd_val(lm);
        band_set_min_vruntime(band, thr_vruntime(tid));
        thr_set(tid, 112, 0);  // lag = 0
        return tid;
    }

    return 0 - 1;  // band truly empty
}

fn pick_next() as i64 {
    // Deadline class first (§4.1)
    if (dl_count() > 0) {
        let is i64 as dl = pick_next_deadline();
        if (dl >= 0) { return dl; }
    }
    // QoS bands in priority order
    let is i64 as b with mut = 0;
    while (b < NUM_QOS_BANDS) {
        if (band_count(b) > 0) {
            let is i64 as tid = pick_next_in_band(b);
            if (tid >= 0) { return tid; }
        }
        b = b + 1;
    }
    return idle_tid();
}

// ============================================================
// account_runtime (§10)
// ============================================================

fn account_runtime(tid as i64, elapsed_ns as i64) as void {
    if (thr_class(tid) == SCHED_CLASS_DEADLINE) {
        dl_account(tid, elapsed_ns);
    }
    if (thr_class(tid) == SCHED_CLASS_QOS) {
        update_vruntime(tid, elapsed_ns);
        qos_budget_check(tid, elapsed_ns);
        update_band_min_vruntime(thr_band(tid));
    }
}

// ============================================================
// schedule (§10)
// ============================================================

fn schedule() as void {
    if (sched_active == 0) { return; }

    asm(".byte 0xFA\n");  // cli

    let is i64 as now = timer.current_time_ns();
    let is i64 as prev = current_tid();

    // Account and re-insert
    if (prev >= 0) {
        if (thr_state(prev) == THREAD_RUNNING) {
            let is i64 as elapsed = now - current_start_ns();
            if (elapsed > 0) {
                account_runtime(prev, elapsed);
            }
            // Re-insert if still runnable (account may have suspended deadline threads)
            if (thr_state(prev) == THREAD_RUNNING) {
                thr_set(prev, 8, THREAD_RUNNABLE);
                if (thr_class(prev) == SCHED_CLASS_DEADLINE) {
                    dl_insert(prev);
                }
                if (thr_class(prev) == SCHED_CLASS_QOS) {
                    runlist_insert(thr_band(prev), prev);
                }
            }
        }
    }

    // Check deadline replenishments
    dl_check_replenish();

    let is i64 as next with mut = pick_next();
    if (next < 0) { next = idle_tid(); }

    // Remove from list
    if (thr_class(next) == SCHED_CLASS_DEADLINE) { dl_remove(next); }
    if (thr_class(next) == SCHED_CLASS_QOS) { runlist_remove(thr_band(next), next); }

    thr_set(next, 8, THREAD_RUNNING);
    set_current_tid(next);
    set_current_start_ns(timer.current_time_ns());
    set_nr_switches(nr_switches() + 1);
    timer.need_resched = 0;

    // Context switch
    if (prev != next) {
        if (prev >= 0) {
            if (thr_state(prev) == THREAD_RUNNABLE) {
                thr_set(prev, 128, thr_get(prev, 128) + 1);
            } else {
                thr_set(prev, 120, thr_get(prev, 120) + 1);
            }

            // FPU: set TS so next thread triggers #NM on first FPU use
            cr0_set_ts();

            ctx_old_rsp_ptr = thread_ptr(prev) + 64;
            ctx_new_rsp = thr_kstack_top(next);

            asm("push r15\n");
            asm("push r14\n");
            asm("push r13\n");
            asm("push r12\n");
            asm("push rbx\n");
            asm("push rbp\n");
            asm("lea rax, [rip+.Lresume]\n");
            asm("push rax\n");
            asm("lea rax, [rip+_kernel_sched_cst_ctx_old_rsp_ptr]\n");
            asm("mov rax, QWORD PTR [rax]\n");
            asm("mov QWORD PTR [rax], rsp\n");
            asm("lea rax, [rip+_kernel_sched_cst_ctx_new_rsp]\n");
            asm("mov rsp, QWORD PTR [rax]\n");
            asm("ret\n");
            asm(".Lresume:\n");
            asm("pop rbp\n");
            asm("pop rbx\n");
            asm("pop r12\n");
            asm("pop r13\n");
            asm("pop r14\n");
            asm("pop r15\n");
        }
    } else {
        asm(".byte 0xFB\n");  // sti
    }

    // Program LAPIC for next event (§12.2)
    program_next_tick();
}

// ============================================================
// Timer tick (§11.3)
// ============================================================

fn on_timer_tick() as void {
    if (sched_active == 0) { return; }

    let is i64 as now = timer.current_time_ns();
    let is i64 as elapsed = now - current_start_ns();

    // Always resched if idle and threads available
    if (current_tid() >= 0) {
        if (thr_class(current_tid()) == SCHED_CLASS_IDLE) {
            if (nr_running() > 0) { timer.need_resched = 1; }
            return;
        }
    }

    // Deadline: check if higher-prio deadline thread became runnable (replenishment)
    dl_check_replenish();

    // Quantum expired?
    if (elapsed >= quantum_ns) {
        timer.need_resched = 1;
    }
}

// ============================================================
// yield
// ============================================================

// ============================================================
// Program next LAPIC tick (§12.2)
// ============================================================

fn program_next_tick() as void {
    if (lapic.calibrated == 0) { return; }

    let is i64 as now = timer.current_time_ns();
    let is i64 as next_event with mut = now + quantum_ns;

    // Check deadline class for sooner events
    if (dl_count() > 0) {
        let is i64 as lm = rb.rb_leftmost(dl_root());
        if (lm != 0) {
            let is i64 as dl = rb.nd_key(lm);
            if (dl < next_event) { next_event = dl; }
        }
    }

    // Check for pending deadline replenishments
    let is i64 as tid with mut = 0;
    while (tid < next_tid) {
        if (thr_class(tid) == SCHED_CLASS_DEADLINE) {
            if (thr_state(tid) == THREAD_SUSPENDED) {
                let is i64 as replenish_at = thr_get(tid, 168) + thr_get(tid, 144);
                if (replenish_at < next_event) { next_event = replenish_at; }
            }
        }
        tid = tid + 1;
    }

    let is i64 as delta with mut = next_event - now;
    if (delta < MIN_QUANTUM_NS) { delta = MIN_QUANTUM_NS; }
    lapic.program_tick_ns(delta);
}

fn yield_cpu() as void { schedule(); }

// ============================================================
// Idle
// ============================================================

fn idle_fn() as void {
    while (1 == 1) {
        if (timer.need_resched != 0) { schedule(); }
        asm(".byte 0xF4\n");
    }
}

// ============================================================
// Init
// ============================================================

fn init() as void {
    serial.println("sched: init", 11);

    // Zero runqueue
    let is *u8 as rqz = cast(*u8, &cpu_rq_raw);
    let is i64 as zi with mut = 0;
    while (zi < RQ_SIZE) { rqz[zi] = 0; zi = zi + 1; }

    // Init TID hash table (initial capacity 64, grows dynamically)
    tid_ht_init(64);

    // Create thread cache for dynamic allocation
    thread_cache = heap.kcache_create(THREAD_SIZE, 64, cast(i32, 0));

    // Init band data
    let is i64 as b with mut = 0;
    while (b < NUM_QOS_BANDS) {
        band_set_count(b, 0);
        band_set_min_vruntime(b, 0);
        b = b + 1;
    }
    rq_set(24, 0 - 1);  // current_tid = -1
    rq_set(40, 0 - 1);  // idle_tid = -1
    rq_set(64, 0 - 1);  // fpu_owner_tid = -1

    // Band budgets (§7.2)
    bb_set(0, 0, 20);  bb_set(0, 1, QOS_WINDOW_NS); bb_set(0, 2, 5); bb_set(0, 3, 3);
    bb_set(1, 0, 70);  bb_set(1, 1, QOS_WINDOW_NS); bb_set(1, 2, 5); bb_set(1, 3, 3);
    bb_set(2, 0, 100); bb_set(2, 1, QOS_WINDOW_NS); bb_set(2, 2, 0); bb_set(2, 3, 0);
    bb_set(3, 0, 100); bb_set(3, 1, QOS_WINDOW_NS); bb_set(3, 2, 0); bb_set(3, 3, 0);
    bb_set(4, 0, 100); bb_set(4, 1, QOS_WINDOW_NS); bb_set(4, 2, 0); bb_set(4, 3, 0);
    bb_set(5, 0, 100); bb_set(5, 1, QOS_WINDOW_NS); bb_set(5, 2, 0); bb_set(5, 3, 0);

    // Create idle thread (allocated dynamically)
    let is i64 as itid = next_tid;
    next_tid = next_tid + 1;
    let is i64 as iptr = heap.kcache_alloc(thread_cache, cast(i32, 0));
    if (iptr == 0) { pmm.panic("idle alloc fail", 15); }
    tid_set_ptr(itid, iptr);

    let is *u8 as tp = cast(*u8, iptr);
    let is i64 as izi with mut = 0;
    while (izi < THREAD_SIZE) { tp[izi] = 0; izi = izi + 1; }

    thr_set(itid, 0, itid);
    thr_set(itid, 8, THREAD_RUNNING);
    thr_set(itid, 16, SCHED_CLASS_IDLE);
    thr_set(itid, 32, BASE_WEIGHT);
    thr_set(itid, 40, DEFAULT_SLICE_NS);

    set_idle_tid(itid);
    set_current_tid(itid);
    set_current_start_ns(timer.current_time_ns());

    serial.println("sched: ready", 12);
}

fn start() as void {
    sched_active = 1;
    serial.println("sched: active", 13);
    idle_fn();
}
