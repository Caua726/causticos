// ioapic.cst — minimal IOAPIC support for routing hardware IRQs to
// driver-framework vectors. Hardcodes the IOAPIC at 0xFEC00000 (legacy);
// ACPI MADT-driven discovery lands when ACPI parsing arrives.

use "vmm.cst" as vmm;
use "serial.cst" as serial;
use "util.cst" as util;

let is i64 as IOAPIC_PHYS = 0xFEC00000;

let is i64 as ioapic_base  with mut = 0;
let is i64 as redir_count  with mut = 0;

fn read_reg(reg as i64) as i64 {
    let is *u32 as sel = cast(*u32, ioapic_base);
    let is *u32 as win = cast(*u32, ioapic_base + 0x10);
    *sel = cast(u32, reg);
    return cast(i64, *win) & 0xFFFFFFFF;
}

fn write_reg(reg as i64, val as i64) as void {
    let is *u32 as sel = cast(*u32, ioapic_base);
    let is *u32 as win = cast(*u32, ioapic_base + 0x10);
    *sel = cast(u32, reg);
    *win = cast(u32, val);
}

fn init() as void {
    ioapic_base = vmm.mmio_map(IOAPIC_PHYS, 4096);
    if (ioapic_base == 0) {
        serial.println("ioapic: mmio_map failed", 23);
        return;
    }
    let is i64 as ver = read_reg(0x01);
    redir_count = ((ver >> 16) & 0xFF) + 1;
    serial.print("ioapic: version=", 16);
    util.print_hex(ver & 0xFF);
    serial.print(" entries=", 9);
    util.print_num(redir_count);
    serial.println("", 0);
}

// Program redirection entry for hardware `irq` to deliver `vector` on the
// CPU with LAPIC ID `dest`. Fixed delivery, physical dest, edge-triggered,
// active-high, unmasked.
fn set_redirection(irq as i64, vector as i64, dest as i64) as void {
    let is i64 as lo_reg = 0x10 + irq * 2;
    let is i64 as hi_reg = lo_reg + 1;
    write_reg(hi_reg, (dest & 0xFF) << 24);
    write_reg(lo_reg, vector & 0xFF);
}

fn mask(irq as i64) as void {
    let is i64 as lo_reg = 0x10 + irq * 2;
    let is i64 as lo = read_reg(lo_reg);
    write_reg(lo_reg, lo | 0x10000);
}
