// gdt.cst — Global Descriptor Table setup

use "serial.cst" as serial;

// GDT entries: null, kernel code, kernel data
// Each entry is 8 bytes. We store as i64 values.
// Entry format: base/limit are ignored in long mode, only flags matter.

let is i64 as gdt_null with mut = 0;
// Kernel code: executable, readable, 64-bit, ring 0
// flags: present=1, DPL=0, S=1, type=0xA (exec/read), L=1 (long mode), D=0, G=1
// raw: 0x00AF9A000000FFFF
let is i64 as gdt_code with mut = 0x00AF9A000000FFFF;
// Kernel data: writable, ring 0
// flags: present=1, DPL=0, S=1, type=0x2 (read/write), G=1
// raw: 0x00CF92000000FFFF
let is i64 as gdt_data with mut = 0x00CF92000000FFFF;

// GDTR: 2 bytes limit + 8 bytes base (10 bytes, packed)
let is i64 as gdtr_limit_base with mut = 0;
let is i64 as gdtr_base_hi with mut = 0;

fn init() as void {
    // GDTR limit = 3 entries * 8 bytes - 1 = 23
    // GDTR base = address of gdt_null
    let is i64 as gdt_base = cast(i64, &gdt_null);
    let is i64 as limit = 23;

    // Pack limit (16 bits) + base (64 bits) into gdtr struct
    // gdtr_limit_base: bits [0:15] = limit, bits [16:63] = base[0:47]
    gdtr_limit_base = limit + ((gdt_base & 0xFFFFFFFFFFFF) << 16);
    // gdtr_base_hi: base[48:63]
    gdtr_base_hi = (gdt_base >> 48) & 0xFFFF;

    // Load GDT
    asm("lea rax, [rip+_kernel_gdt_cst_gdtr_limit_base]\n");
    asm(".byte 0x0F, 0x01, 0x10\n");  // lgdt [rax]

    // Reload CS via far return
    asm("push 0x08\n");               // kernel code selector
    asm("lea rax, [rip+.Lreload_cs]\n");
    asm("push rax\n");
    asm(".byte 0x48, 0xCB\n");        // retfq (far return)
    asm(".Lreload_cs:\n");

    // Reload data segments
    asm("mov ax, 0x10\n");            // kernel data selector
    asm("mov ds, ax\n");
    asm("mov es, ax\n");
    asm("mov fs, ax\n");
    asm("mov gs, ax\n");
    asm("mov ss, ax\n");

    serial.println("gdt: ok", 7);
}
