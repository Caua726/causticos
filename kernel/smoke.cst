// smoke.cst — MMIO + IRQ smoke tests, decoupled from any particular driver.
//
// Previously these were inlined into dummy_probe; moving them out gives
// dummybus.cst a single responsibility (being a synthetic bus for the
// framework) and lets the smoke runner own per-device state via Device.private.

use "driver.cst" as driver;
use "heap.cst" as heap;
use "serial.cst" as serial;
use "util.cst" as util;

// Per-device smoke state. Allocated by setup_state and stashed in
// dev.private; irq_handler reads it back from the same field.
struct SmokeState {
    irq_hit_count as i64;
    mmio_done as i32;
    irq_done as i32;
}

fn setup_state(dev as *driver.Device) as *SmokeState {
    if (cast(i64, dev.private) != 0) {
        return cast(*SmokeState, dev.private);
    }
    let is i64 as addr = heap.kmalloc(sizeof(SmokeState), 0);
    if (addr == 0) { return cast(*SmokeState, 0); }
    let is *SmokeState as s = cast(*SmokeState, addr);
    s.irq_hit_count = 0;
    s.mmio_done = 0;
    s.irq_done = 0;
    dev.private = cast(*u8, addr);
    return s;
}

fn irq_handler(dev as *driver.Device, ctx as *u8) as i32 {
    let is *SmokeState as s = cast(*SmokeState, dev.private);
    if (cast(i64, s) != 0) { s.irq_hit_count = s.irq_hit_count + 1; }
    return 0;  // HANDLED
}

// Exercises the framework's mmio_map primitive by mapping the LAPIC base
// (0xFEE00000) uncached and reading its APIC ID register.
fn run_mmio(dev as *driver.Device) as void {
    let is *SmokeState as s = setup_state(dev);
    if (cast(i64, s) == 0 || s.mmio_done == 1) { return; }
    s.mmio_done = 1;

    serial.println("smoke: calling mmio_map...", 26);
    let is *u8 as lapic_virt with mut = cast(*u8, 0);
    let is i32 as rc = driver.mmio_map(dev, cast(u64, 0xFEE00000),
                                       cast(u64, 4096), cast(u32, 0),
                                       &lapic_virt);
    serial.print("smoke: mmio_map rc=", 19);
    util.print_num(cast(i64, rc));
    serial.println("", 0);
    if (rc != driver.OK) { return; }

    serial.print("smoke: lapic vaddr=", 19);
    util.print_hex(cast(i64, lapic_virt));
    serial.println("", 0);
    let is *u32 as id_reg = cast(*u32, cast(i64, lapic_virt) + 0x20);
    let is u32 as raw = *id_reg;
    serial.print("smoke: lapic id=", 16);
    util.print_num(cast(i64, raw) >> 24);
    serial.println("", 0);
}

// Exercises the framework's irq_register dispatch path by registering a
// handler on vector 48 and firing `int 0x30` in software.
fn run_irq(dev as *driver.Device) as void {
    let is *SmokeState as s = setup_state(dev);
    if (cast(i64, s) == 0 || s.irq_done == 1) { return; }
    s.irq_done = 1;

    let is i32 as rc = driver.irq_register(dev, cast(u32, 48), cast(i32, 0),
                                           fn_ptr(irq_handler),
                                           cast(*u8, 0));
    serial.print("smoke: irq_register rc=", 23);
    util.print_num(cast(i64, rc));
    serial.println("", 0);
    if (rc != driver.OK) { return; }

    serial.println("smoke: firing int 0x30...", 25);
    asm("int 0x30\n");
    serial.println("smoke: int 0x30 returned", 24);
    serial.print("smoke: irq_hit_count=", 21);
    util.print_num(s.irq_hit_count);
    serial.println("", 0);
}
