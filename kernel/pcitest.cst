// pcitest.cst — minimal PCI driver that probes the e1000 (8086:100e).
// Proves bus_type match -> driver selection -> probe callback with a
// PciDevice handed to the driver. Does not drive the NIC.

use "driver.cst" as driver;
use "pci.cst" as pci;
use "serial.cst" as serial;
use "util.cst" as util;

let is pci.PciMatchSpec as e1000_spec;
let is driver.Driver    as e1000_drv;

fn e1000_probe(dev as *driver.Device) as i32 {
    let is *pci.PciDevice as pd = cast(*pci.PciDevice, dev);
    serial.print("e1000: probe matched ", 21);
    util.print_num(cast(i64, pd.bus));
    serial.putc(58);
    util.print_num(cast(i64, pd.dev));
    serial.putc(46);
    util.print_num(cast(i64, pd.func));
    serial.print(" bar0=", 6);
    util.print_hex(cast(i64, pd.bar0));
    serial.println("", 0);
    return driver.OK;
}

fn e1000_remove(dev as *driver.Device) as void {
}

fn register() as void {
    e1000_spec.vendor = 0x8086;
    e1000_spec.device = 0x100E;

    e1000_drv.name[0] = cast(u8, 101); // 'e'
    e1000_drv.name[1] = cast(u8, 49);  // '1'
    e1000_drv.name[2] = cast(u8, 48);  // '0'
    e1000_drv.name[3] = cast(u8, 48);  // '0'
    e1000_drv.name[4] = cast(u8, 48);  // '0'
    e1000_drv.priority   = 50;
    e1000_drv.match_spec = cast(*u8, &e1000_spec);
    e1000_drv.probe      = fn_ptr(e1000_probe);
    e1000_drv.remove     = fn_ptr(e1000_remove);
    driver.bus_register_driver(&pci.pci_bt, &e1000_drv);
}
