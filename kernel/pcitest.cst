// pcitest.cst — e1000 (82540EM) driver, step 1.
// MMIO-map BAR0, read device STATUS + permanent MAC from RAL0/RAH0.
// No ring setup or IRQ yet — those arrive in later steps.

use "driver.cst" as driver;
use "pci.cst" as pci;
use "serial.cst" as serial;
use "util.cst" as util;

// BAR0 is 128 KB of memory-mapped registers.
let is i64 as E1000_BAR0_SIZE = 0x20000;

// Register offsets we touch in step 1.
let is i64 as E1000_STATUS = 0x0008;
let is i64 as E1000_RAL0   = 0x5400;
let is i64 as E1000_RAH0   = 0x5404;

let is pci.PciMatchSpec as e1000_spec;
let is driver.Driver    as e1000_drv;

fn read32(regs as *u8, off as i64) as i64 {
    let is *u32 as p = cast(*u32, cast(i64, regs) + off);
    return cast(i64, *p) & 0xFFFFFFFF;
}

fn print_mac(ral as i64, rah as i64) as void {
    let is i64 as b0 = ral & 0xFF;
    let is i64 as b1 = (ral >> 8)  & 0xFF;
    let is i64 as b2 = (ral >> 16) & 0xFF;
    let is i64 as b3 = (ral >> 24) & 0xFF;
    let is i64 as b4 = rah & 0xFF;
    let is i64 as b5 = (rah >> 8) & 0xFF;
    util.print_hex(b0); serial.putc(58);
    util.print_hex(b1); serial.putc(58);
    util.print_hex(b2); serial.putc(58);
    util.print_hex(b3); serial.putc(58);
    util.print_hex(b4); serial.putc(58);
    util.print_hex(b5);
}

fn e1000_probe(dev as *driver.Device) as i32 {
    let is *pci.PciDevice as pd = cast(*pci.PciDevice, dev);
    serial.print("e1000: probe ", 13);
    util.print_num(cast(i64, pd.bus));
    serial.putc(58);
    util.print_num(cast(i64, pd.dev));
    serial.putc(46);
    util.print_num(cast(i64, pd.func));
    serial.print(" bar0=", 6);
    util.print_hex(cast(i64, pd.bar0));
    serial.println("", 0);

    let is *u8 as regs with mut = cast(*u8, 0);
    let is i32 as rc = driver.mmio_map(dev, cast(u64, pd.bar0),
                                       cast(u64, E1000_BAR0_SIZE),
                                       cast(u32, 0), &regs);
    if (rc != driver.OK) {
        serial.print("e1000: mmio_map rc=", 19);
        util.print_num(cast(i64, rc));
        serial.println("", 0);
        return rc;
    }

    let is i64 as status = read32(regs, E1000_STATUS);
    serial.print("e1000: status=", 14);
    util.print_hex(status);
    if ((status & 0x2) != 0) {
        serial.print(" link=up", 8);
    } else {
        serial.print(" link=down", 10);
    }
    if ((status & 0x1) != 0) {
        serial.print(" fd", 3);
    }
    serial.println("", 0);

    let is i64 as ral = read32(regs, E1000_RAL0);
    let is i64 as rah = read32(regs, E1000_RAH0);
    serial.print("e1000: mac=", 11);
    print_mac(ral, rah);
    serial.println("", 0);

    return driver.OK;
}

fn e1000_remove(dev as *driver.Device) as void {
}

fn register() as void {
    e1000_spec.vendor = 0x8086;
    e1000_spec.device = 0x100E;

    e1000_drv.name[0] = cast(u8, 101); // 'e'
    e1000_drv.name[1] = cast(u8, 49);  // '1'
    e1000_drv.name[2] = cast(u8, 48);  // '0'
    e1000_drv.name[3] = cast(u8, 48);  // '0'
    e1000_drv.name[4] = cast(u8, 48);  // '0'
    e1000_drv.priority   = 50;
    e1000_drv.match_spec = cast(*u8, &e1000_spec);
    e1000_drv.probe      = fn_ptr(e1000_probe);
    e1000_drv.remove     = fn_ptr(e1000_remove);
    driver.bus_register_driver(&pci.pci_bt, &e1000_drv);
}
