// kbd.cst — PS/2 keyboard driver.
// IRQ 1 is routed through the IOAPIC to vector 49, dispatched by the
// driver framework. The handler reads the scan code from port 0x60 and
// logs it on serial — no key-state translation yet.

use "driver.cst" as driver;
use "platform.cst" as platform;
use "port.cst" as port;
use "serial.cst" as serial;
use "util.cst" as util;

let is i64 as KBD_IRQ    = 1;
let is i64 as KBD_VECTOR = 49;

fn handler(dev as *driver.Device, ctx as *u8) as i32 {
    let is i64 as sc = port.inb(0x60);
    serial.print("kbd: sc=", 8);
    util.print_hex(sc);
    serial.println("", 0);
    return 0;
}

fn init() as void {
    let is i32 as rc = driver.irq_register(driver.get_root(),
                                           cast(u32, KBD_VECTOR),
                                           cast(i32, 0),
                                           fn_ptr(handler),
                                           cast(*u8, 0));
    if (rc != driver.OK) {
        serial.print("kbd: irq_register failed rc=", 28);
        util.print_num(cast(i64, rc));
        serial.println("", 0);
        return;
    }
    platform.set_irq_route(KBD_IRQ, KBD_VECTOR, 0);
    serial.println("kbd: ready", 10);
}
